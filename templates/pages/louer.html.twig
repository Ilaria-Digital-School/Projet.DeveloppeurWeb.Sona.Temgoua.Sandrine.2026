{% extends 'base.html.twig' %}

{% block title %}{% trans %}Louer sur Shareo{% endtrans %}{% endblock %}

{% block body %}


<!-- HERO -->

<section
  class="position-relative text-white py-5"
  style="
    background-image: url('{{ asset('images/louerhero.png') }}');
    background-size: cover;
    background-position: center;
  "
>
  <!-- Overlay -->
  <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-50"></div>

  <!-- Contenu -->
  <div class="container min-vh-50 position-relative d-flex align-items-center justify-content-center text-center">
    <div class="col-lg-8">
      <h1 class="fw-bold mb-2">
        {% trans %}Louez ce dont vous avez besoin, quand vous en avez besoin{% endtrans %}
      </h1>

      <p class="lead mb-4">
       <strong>{% trans %}Économisez de l'argent et de l'espace grâce à la location.{% endtrans %}</strong>
      </p>
      
<!-- Boutons -->
      <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-5">
          {% trans %}Parcourir les locations{% endtrans %}
        </a>
        {# Bouton qui redirige vers la page register si visiteur non connecté #}
			{% if app.user %}
    <a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-5">
        {% trans %}Publier une annonce{% endtrans %}
    </a>
{% else %}
    <a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-5">
        {% trans %}Publier une annonce{% endtrans %}
    </a>
{% endif %}

        <a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-5">
          {% trans %}Comment ça marche ?{% endtrans %}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- PRODUITS À LOUER -->

{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}

<!-- HOW IT WORKS -->
<section id="how-it-works" class="py-5 bg-light">
    <div class="container">
        <h2 class="fw-bold text-center text-dark mb-5">
            {% trans %}Comment louer sur Shareo ?{% endtrans %}
        </h2>

        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="card border-0 h-100">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">1</h1>
                        <h5 class="fw-bold">{% trans %}Choisissez{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Sélectionnez votre produit et la durée{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 h-100">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">2</h1>
                        <h5 class="fw-bold">{% trans %}Réservez{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Paiement sécurisé et contrat en ligne{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 h-100">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">3</h1>
                        <h5 class="fw-bold">{% trans %}Profitez{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Livraison ou retrait selon votre choix{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- AVANTAGES -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="fw-bold text-center text-dark mb-5">
            {% trans %}Pourquoi louer sur Shareo ?{% endtrans %}
        </h2>

        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-euro-sign fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">{% trans %}Économique{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Payez uniquement le temps d'utilisation, jusqu'à 80% moins cher que l'achat.{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-leaf fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">{% trans %}Écologique{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Moins de surconsommation, plus de partage et moins de déchets.{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-tools fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">{% trans %}Pratique{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Accédez à des produits spécialisés sans engagement.{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}