{% extends 'base.html.twig' %}

{% block title %}{% trans %}Louer sur 𝒮araka{% endtrans %}{% endblock %}

{% block body %}


<!-- HERO -->


<section
    class="hero-page position-relative text-white"
    style="background-image: url('{{ asset('images/heroacheter.avif') }}');"
>

    <div class="hero-page-overlay"></div>

    <div class="container hero-page-content">
        <div class="col-lg-8 mx-auto text-center">

            <h1 class="hero-page-title fw-bold mb-3">
                {% trans %}Louez ce dont vous avez besoin, quand vous en avez besoin{% endtrans %}
            </h1>

            <p class="hero-page-subtitle lead mb-4">
                {% trans %}
                Économisez de l'argent et de l'espace grâce à la location. Accédez à des produits de qualité sans les acheter, tout en réduisant votre impact environnemental.
                 {% endtrans %}
            </p>
        
<!-- Boutons CTA -->
      <div class="d-flex justify-content-center gap-2 flex-wrap">
        <a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-3">
          {% trans %}Parcourir les locations{% endtrans %}
        </a>
        {# Bouton qui redirige vers la page register si visiteur non connecté #}
			{% if app.user %}
    <a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
        {% trans %}Publier une annonce{% endtrans %}
    </a>
{% else %}
    <a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
        {% trans %}Publier une annonce{% endtrans %}
    </a>
{% endif %}

        <a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-3">
          {% trans %}Comment ça marche ?{% endtrans %}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- PRODUITS À LOUER -->

{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}

<!-- HOW IT WORKS -->
<section id="how-it-works" class="py-5 bg-light">
    <div class="container">
        <h2 class="fw-bold text-center text-dark mb-5">
            {% trans %}Comment louer sur 𝒮araka ?{% endtrans %}
        </h2>

        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="card border-0 h-100">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">1</h1>
                        <h5 class="fw-bold">{% trans %}Choisissez{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Sélectionnez votre produit et la durée{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 h-100">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">2</h1>
                        <h5 class="fw-bold">{% trans %}Réservez{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Paiement sécurisé et contrat en ligne{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 h-100">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">3</h1>
                        <h5 class="fw-bold">{% trans %}Profitez{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Livraison ou retrait selon votre choix{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- AVANTAGES -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="fw-bold text-center text-dark mb-5">
            {% trans %}Pourquoi louer sur 𝒮araka ?{% endtrans %}
        </h2>

        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-euro-sign fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">{% trans %}Économique{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Payez uniquement le temps d'utilisation, jusqu'à 80% moins cher que l'achat.{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-leaf fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">{% trans %}Écologique{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Moins de surconsommation, plus de partage et moins de déchets.{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-tools fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">{% trans %}Pratique{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Accédez à des produits spécialisés sans engagement.{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}