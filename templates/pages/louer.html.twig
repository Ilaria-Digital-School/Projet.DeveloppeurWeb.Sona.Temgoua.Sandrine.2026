{% extends 'base.html.twig' %}

{% block title %}{% trans %}Louer sur 𝒮araka{% endtrans %}{% endblock %}

{% block body %}


<!-- HERO -->


<section
    class="hero-page position-relative text-white"
    style="background-image: url('{{ asset('images/louerhero.png') }}');"
>

    <div class="hero-page-overlay"></div>

    <div class="container hero-page-content">
        <div class="col-lg-8 mx-auto text-center">

            <h1 class="hero-page-title fw-bold mb-3">
                {% trans %}Louez ce dont vous avez besoin, quand vous en avez besoin{% endtrans %}
            </h1>

            <p class="hero-page-subtitle lead mb-4 text-white fw-medium">
                {% trans %}
                Économisez de l'argent et de l'espace grâce à la location. Accédez à des produits de qualité sans les acheter, tout en réduisant votre impact environnemental.
                 {% endtrans %}
            </p>
        
<!-- Boutons CTA -->
      <div class="d-flex justify-content-center gap-2 flex-wrap">
        <a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-3">
          {% trans %}Parcourir les locations{% endtrans %}
        </a>
        {# Bouton qui redirige vers la page register si visiteur non connecté #}
			{% if app.user %}
    <a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
        {% trans %}Publier une annonce{% endtrans %}
    </a>
{% else %}
    <a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
        {% trans %}Publier une annonce{% endtrans %}
    </a>
{% endif %}

        <a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-3">
          {% trans %}Comment ça marche ?{% endtrans %}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- PRODUITS À LOUER -->

{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}
<!-- HOW IT WORKS -->

<section id="how-it-works" class="how-section py-5">

<div class="container">

    <div class="text-center mb-5">

        <span class="section-label">
            {% trans %}Comment ça marche{% endtrans %}
        </span>

        <h2 class="fw-bold mt-3">
            {% trans %}Comment vendre ou acheter en brocante sur 𝒮araka ?{% endtrans %}
        </h2>

        <p class="text-muted mx-auto how-intro">
            {% trans %}
            Donnez une seconde vie aux objets grâce à la brocante entre particuliers.
            {% endtrans %}
        </p>

    </div>

    <div class="row g-4">

        <!-- Etape 1 -->
        <div class="col-md-6 col-lg-4">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">1</div>

                    <h3 class="how-title">
                        {% trans %}Parcourez les annonces{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Découvrez des objets d'occasion proposés par des particuliers et trouvez la bonne affaire près de chez vous.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Etape 2 -->
        <div class="col-md-6 col-lg-4">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">2</div>

                    <h3 class="how-title">
                        {% trans %}Contactez le vendeur{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Échangez via la messagerie Saraka afin de poser vos questions, convenir du prix et organiser la remise de l'objet.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Etape 3 -->
        <div class="col-md-6 col-lg-4">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">3</div>

                    <h3 class="how-title">
                        {% trans %}Finalisez l'échange{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Rencontrez le vendeur, vérifiez l'état de l'objet et repartez avec votre achat en toute simplicité.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

</section>

<!-- AVANTAGES BROCANTE -->

<section class="advantages-section py-5">

<div class="container">

    <div class="text-center mb-5">

        <span class="section-label">
            {% trans %}Les avantages{% endtrans %}
        </span>

        <h2 class="fw-bold mt-3">
            {% trans %}Pourquoi choisir la brocante sur 𝒮araka ?{% endtrans %}
        </h2>

        <p class="text-muted advantages-intro">
            {% trans %}
            Acheter ou vendre en brocante sur Saraka, c'est faire des économies tout en donnant une seconde vie aux objets.
            {% endtrans %}
        </p>

    </div>

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-tags"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Bonnes affaires{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Achetez ou vendez des objets d'occasion à des prix attractifs.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-recycle"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Écoresponsable{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Offrez une nouvelle vie aux objets et réduisez le gaspillage.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-users"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Convivial et Local{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Favorisez les échanges entre particuliers et participez à une économie de proximité.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

</section>

{% endblock %}