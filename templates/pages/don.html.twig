{% extends 'base.html.twig' %}

{% block title %}Donner sur shareo{% endblock %}

{% block body %}

<!-- HERO -->
<section
  class="position-relative text-white py-5"
  style="
    background-image: url('{{ asset('images/donhero.jpg') }}');
    background-size: cover;
    background-position: center;
  "
>
  <!-- Overlay -->
  <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-50"></div>

  <!-- Contenu -->
  <div class="container min-vh-50 position-relative d-flex align-items-center justify-content-center text-center">
    <div class="col-lg-8">
      <h1 class="fw-bold mb-4">
        Faites un don, changez des vies
      </h1>

      <p class="lead mb-4">
       <strong>Découvrez les objets déjà offerts par la communauté Shareo
                et donnez une seconde vie à ce que vous n’utilisez plus.</strong>
      </p>

      <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-5">
          Voir les dons disponibles
        </a>
        <a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-5">
          Déposer un don
        </a>
      </div>
    </div>
  </div>
</section>

<!-- PRODUITS À DONNER -->
{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}

<!-- CTA -->
<section class="py-5 bg-dark text-white text-center">
    <div class="container">
        <h2 class="fw-bold mb-3">
            Vous aussi, proposez un don
        </h2>
        <p class="mb-4">
            Un objet inutilisé peut faire le bonheur de quelqu’un d’autre.
        </p>
        <a href="#" class="btn btn-outline-warning btn-lg rounded-pill px-5">
            Déposer un don
        </a>
    </div>
</section>

{% endblock %}
