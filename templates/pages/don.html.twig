{% extends 'base.html.twig' %}

{% block title %}
	{% trans %}Donner sur saraka{% endtrans %}
{% endblock %}

{% block body %}

	<!-- HERO -->
	<section
		class="position-relative min-vh-90 text-white py-4" style="
			    background-image: url('{{ asset('images/donhero.jpg') }}');
			    background-size: cover;
			    background-position: center;
				height: 65vh;
			  ">
		<!-- Overlay -->
		<div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-50"></div>

		<!-- Contenu -->
		<div class="container min-vh-50 position-relative d-flex align-items-center justify-content-center text-center">
			<div class="col-lg-8">
				<h1 class="display-3 fw-bold hero-title mb-0" style="font-family: 'Playfair Display', serif; text-shadow: 2px 2px 4px rgba(0,0,0,0.7);">
					{% trans %}Faites un don, changez des vies.{% endtrans %}
				</h1>

				<p class="vision-text text-center text-light mx-auto">
					{% trans %}Donnez une seconde vie à ce que vous n'utilisez plus. Un objet oublié peut faire le bonheur de quelqu'un d'autre.{% endtrans %}
				</p>

				<div class="d-flex justify-content-center gap-2 flex-wrap">
					<a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-3">
						{% trans %}Voir les dons disponibles{% endtrans %}
					</a>

					{# Bouton qui redirige vers la page register si visiteur non connecté #}
					{% if app.user %}
						<a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% else %}
						<a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% endif %}

				</a>
				<a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-3">
					{% trans %}Comment ça marche ?{% endtrans %}
				</a>
			</div>
		</div>
	</div>
</section>

<!-- PRODUITS À DONNER -->
{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}

<!-- HOW IT WORKS DON -->
<section id="how-it-works" class="py-5 bg-light">
	<div class="container">
		<h2 class="fw-bold text-center text-dark mb-5">
			{% trans %}Comment donner sur saraka ?{% endtrans %}
		</h2>

		<div class="row g-4 text-center">
			<div class="col-md-4">
				<div class="card border-0 h-100">
					<div class="card-body">
						<h1 class="fw-bold text-success">1</h1>
						<h5>{% trans %}Publiez gratuitement{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Ajoutez votre objet à donner avec photos et description, en quelques clics.{% endtrans %}
						</p>
					</div>
				</div>
			</div>

			<div class="col-md-4">
				<div class="card border-0 h-100">
					<div class="card-body">
						<h1 class="fw-bold text-success">2</h1>
						<h5>{% trans %}Entrez en contact{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Échangez avec des personnes intéressées près de chez vous.{% endtrans %}
						</p>
					</div>
				</div>
			</div>

			<div class="col-md-4">
				<div class="card border-0 h-100">
					<div class="card-body">
						<h1 class="fw-bold text-success">3</h1>
						<h5>{% trans %}Transmettez{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Remettez votre objet en main propre et offrez-lui une seconde vie.{% endtrans %}
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- AVANTAGES DON -->
<section class="py-5 bg-light">
	<div class="container">
		<h2 class="fw-bold text-center text-dark mb-5">
			{% trans %}Pourquoi donner sur saraka ?{% endtrans %}
		</h2>

		<div class="row g-4 text-center">
			<div class="col-md-4">
				<div class="card h-100 border-0 shadow-sm">
					<div class="card-body">
						<i class="fas fa-hand-holding-heart fa-2x text-success mb-3"></i>
						<h5 class="fw-bold">{% trans %}Solidaire{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Aidez des personnes près de chez vous en donnant ce dont vous n'avez plus besoin.{% endtrans %}
						</p>
					</div>
				</div>
			</div>

			<div class="col-md-4">
				<div class="card h-100 border-0 shadow-sm">
					<div class="card-body">
						<i class="fas fa-recycle fa-2x text-success mb-3"></i>
						<h5 class="fw-bold">{% trans %}Écologique{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Réduisez le gaspillage en offrant une seconde vie à vos objets.{% endtrans %}
						</p>
					</div>
				</div>
			</div>

			<div class="col-md-4">
				<div class="card h-100 border-0 shadow-sm">
					<div class="card-body">
						<i class="fas fa-smile fa-2x text-success mb-3"></i>
						<h5 class="fw-bold">{% trans %}Simple & Humain{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Un geste simple, gratuit et local qui crée du lien dans votre communauté.{% endtrans %}
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
{% endblock %}

 
