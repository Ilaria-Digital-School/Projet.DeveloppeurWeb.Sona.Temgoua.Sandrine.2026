{% extends 'base.html.twig' %}

{% block title %}
	{% trans %}Donner sur 𝒮araka{% endtrans %}
{% endblock %}

{% block body %}

	<!-- HERO -->


	<section
    class="hero-page position-relative text-white"
    style="background-image: url('{{ asset('images/donhero.jpg') }}');"
>

    <div class="hero-page-overlay"></div>

    <div class="container hero-page-content">
        <div class="col-lg-8 mx-auto text-center">

            <h1 class="hero-page-title fw-bold mb-3">
                {% trans %}Faites un don, changez des vies.{% endtrans %}
            </h1>

            <p class="hero-page-subtitle lead mb-4 text-white fw-medium">
                {% trans %}
                Un objet oublié peut faire le bonheur de quelqu'un d'autre. Donnez ce dont vous n'avez plus besoin et offrez une seconde vie à vos objets, tout en créant du lien dans votre communauté.
                 {% endtrans %}
            </p>

				<!-- Boutons CTA -->


				<div class="d-flex justify-content-center gap-2 flex-wrap">
					<a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-3">
						{% trans %}Voir les dons disponibles{% endtrans %}
					</a>

					{# Bouton qui redirige vers la page register si visiteur non connecté #}
					{% if app.user %}
						<a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% else %}
						<a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% endif %}

				</a>
				<a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-3">
					{% trans %}Comment ça marche ?{% endtrans %}
				</a>
			</div>
		</div>
	</div>
</section>

<!-- PRODUITS À DONNER -->
{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}

<!-- HOW IT WORKS DON -->
<section id="how-it-works" class="py-5 bg-light">
	<div class="container">
		<h2 class="fw-bold text-center text-dark mb-5">
			{% trans %}Comment donner sur 𝒮araka ?{% endtrans %}
		</h2>

		<div class="row g-4 text-center">
			<div class="col-md-4">
				<div class="card border-0 h-100">
					<div class="card-body">
						<h1 class="fw-bold text-success">1</h1>
						<h5>{% trans %}Publiez gratuitement{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Ajoutez votre objet à donner avec photos et description, en quelques clics.{% endtrans %}
						</p>
					</div>
				</div>
			</div>

			<div class="col-md-4">
				<div class="card border-0 h-100">
					<div class="card-body">
						<h1 class="fw-bold text-success">2</h1>
						<h5>{% trans %}Entrez en contact{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Échangez avec des personnes intéressées près de chez vous.{% endtrans %}
						</p>
					</div>
				</div>
			</div>

			<div class="col-md-4">
				<div class="card border-0 h-100">
					<div class="card-body">
						<h1 class="fw-bold text-success">3</h1>
						<h5>{% trans %}Transmettez{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Remettez votre objet en main propre et offrez-lui une seconde vie.{% endtrans %}
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- AVANTAGES DON -->
<section class="py-5 bg-light">
	<div class="container">
		<h2 class="fw-bold text-center text-dark mb-5">
			{% trans %}Pourquoi donner sur 𝒮araka ?{% endtrans %}
		</h2>

		<div class="row g-4 text-center">
			<div class="col-md-4">
				<div class="card h-100 border-0 shadow-sm">
					<div class="card-body">
						<i class="fas fa-hand-holding-heart fa-2x text-success mb-3"></i>
						<h5 class="fw-bold">{% trans %}Solidaire{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Aidez des personnes près de chez vous en donnant ce dont vous n'avez plus besoin.{% endtrans %}
						</p>
					</div>
				</div>
			</div>

			<div class="col-md-4">
				<div class="card h-100 border-0 shadow-sm">
					<div class="card-body">
						<i class="fas fa-recycle fa-2x text-success mb-3"></i>
						<h5 class="fw-bold">{% trans %}Écologique{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Réduisez le gaspillage en offrant une seconde vie à vos objets.{% endtrans %}
						</p>
					</div>
				</div>
			</div>

			<div class="col-md-4">
				<div class="card h-100 border-0 shadow-sm">
					<div class="card-body">
						<i class="fas fa-smile fa-2x text-success mb-3"></i>
						<h5 class="fw-bold">{% trans %}Simple & Humain{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Un geste simple, gratuit et local qui crée du lien dans votre communauté.{% endtrans %}
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
<!-- Call to action -->
<section class="about-cta py-5">

    <div class="container">

        <div class="cta-card text-center">

            <div class="section-label">
                {% trans %}Rejoignez-nous{% endtrans %}
            </div>

            <h1 class="display-5 fw-bold mb-4">

                {% trans %}
                Construisons ensemble une économie plus humaine
                {% endtrans %}

            </h1>

            <p class="lead mb-4">

                {% trans %}
                Chaque objet partagé, chaque service rendu et chaque rencontre
                contribue à bâtir une communauté plus forte.
                {% endtrans %}

            </p>

            <a href="{{ path('app_register') }}"
               class="btn btn-success btn-lg rounded-pill px-5">

                {% trans %}Créer un compte{% endtrans %}

            </a>

        </div>

    </div>

</section>
{% endblock %}

 
