{% extends 'base.html.twig' %}

{% block title %}
	{% trans %}Donner sur 𝒮araka{% endtrans %}
{% endblock %}

{% block body %}

	<!-- HERO -->


	<section
    class="hero-page position-relative text-white"
    style="background-image: url('{{ asset('images/donhero.jpg') }}');"
>

    <div class="hero-page-overlay"></div>

    <div class="container hero-page-content">
        <div class="col-lg-8 mx-auto text-center">

            <h1 class="hero-page-title fw-bold mb-3">
                {% trans %}Faites un don, changez des vies.{% endtrans %}
            </h1>

            <p class="hero-page-subtitle lead mb-4 text-white fw-medium">
                {% trans %}
                Un objet oublié peut faire le bonheur de quelqu'un d'autre. Donnez ce dont vous n'avez plus besoin et offrez une seconde vie à vos objets, tout en créant du lien dans votre communauté.
                 {% endtrans %}
            </p>

				<!-- Boutons CTA -->


				<div class="d-flex justify-content-center gap-2 flex-wrap">
					<a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-3">
						{% trans %}Voir les dons disponibles{% endtrans %}
					</a>

					{# Bouton qui redirige vers la page register si visiteur non connecté #}
					{% if app.user %}
						<a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% else %}
						<a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% endif %}

				</a>
				<a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-3">
					{% trans %}Comment ça marche ?{% endtrans %}
				</a>
			</div>
		</div>
	</div>
</section>

<!-- PRODUITS À DONNER -->
{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}

<!-- HOW IT WORKS -->

<section id="how-it-works" class="how-section py-5">

<div class="container">

    <div class="text-center mb-5">

        <span class="section-label">
            {% trans %}Comment ça marche{% endtrans %}
        </span>

        <h2 class="fw-bold mt-3">
            {% trans %}Comment donner sur 𝒮araka ?{% endtrans %}
        </h2>

        <p class="text-muted mx-auto how-intro">
            {% trans %}
            Offrez une seconde vie à vos objets en quelques étapes simples.
            {% endtrans %}
        </p>

    </div>

    <div class="row g-4">

        <!-- Etape 1 -->
        <div class="col-md-6 col-lg-4">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">
                        1
                    </div>

                    <h3 class="how-title">
                        {% trans %}Publiez gratuitement{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Ajoutez votre objet à donner avec quelques photos et une description.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Etape 2 -->
        <div class="col-md-6 col-lg-4">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">
                        2
                    </div>

                    <h3 class="how-title">
                        {% trans %}Entrez en contact{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Discutez avec les personnes intéressées directement depuis Saraka. Choisissez le receveur parmi les demandes reçues.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Etape 3 -->
        <div class="col-md-6 col-lg-4">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">
                        3
                    </div>

                    <h3 class="how-title">
                        {% trans %}Organisez la livraison{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Fixez un rendez-vous avec le receveur ou utilisez des points relais pour livrer votre objet et offrez-lui une nouvelle vie.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>
</section>

<!-- AVANTAGES DON -->

<section class="advantages-section py-5">

<div class="container">

    <div class="text-center mb-5">

        <span class="section-label">
            {% trans %}Les avantages{% endtrans %}
        </span>

        <h2 class="fw-bold mt-3">
            {% trans %}Pourquoi donner sur 𝒮araka ?{% endtrans %}
        </h2>

        <p class="text-muted advantages-intro">
            {% trans %}
            Donner sur Saraka, c'est faire un geste simple qui profite à la fois
            aux personnes, à la planète et à votre communauté.
            {% endtrans %}
        </p>

    </div>

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-hand-holding-heart"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Solidaire{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Aidez des personnes près de chez vous en donnant ce dont vous n'avez plus besoin.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-recycle"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Écologique{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Réduisez le gaspillage en offrant une seconde vie à vos objets.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-smile"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Simple & Humain{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Un geste simple, gratuit et local qui crée du lien dans votre communauté.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

</section>

{% endblock %}

 
