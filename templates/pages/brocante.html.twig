{% extends 'base.html.twig' %}

{% block title %}{% trans %}Brocante sur 𝒮araka{% endtrans %}{% endblock %}

{% block body %}

<!-- HERO -->

<section
    class="hero-page position-relative text-white"
    style="background-image: url('{{ asset('images/herobrocante.png') }}');"
>

    <div class="hero-page-overlay"></div>

    <div class="container hero-page-content">
        <div class="col-lg-8 mx-auto text-center">

            <h1 class="hero-page-title fw-bold mb-3">
                {% trans %}Vendez en gros,libérez votre espace{% endtrans %}
            </h1>

            <p class="hero-page-subtitle lead mb-4 text-white fw-medium">
                {% trans %}
                Débarrassez-vous de vos encombrants sans bouger de chez vous. Organisez votre vide-grenier en ligne et trouvez preneurs plus rapidement sans tracasseries logistiques.
                 {% endtrans %}
            </p>

<!-- Boutons CTA -->
    <div class="d-flex justify-content-center gap-2 flex-wrap">
      <a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-3">
        {% trans %}Parcourir les annonces{% endtrans %}
      </a>
      
      {# Bouton qui redirige vers la page register si visiteur non connecté #}
			{% if app.user %}
    <a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
        {% trans %}Publier une annonce{% endtrans %}
    </a>
{% else %}
    <a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
        {% trans %}Publier une annonce{% endtrans %}
    </a>
{% endif %}

      <a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-3">
        {% trans %}Comment ça marche ?{% endtrans %}
      </a>
    </div>
  </div>
</div>
</section>

 
<!-- PRODUITS À VENDRE -->

{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}

<!-- HOW IT WORKS -->

<section id="how-it-works" class="how-section py-5">

<div class="container">

    <div class="text-center mb-5">

        <span class="section-label">
            {% trans %}Comment ça marche{% endtrans %}
        </span>

        <h2 class="fw-bold mt-3">
            {% trans %}Comment vendre en brocante sur 𝒮araka ?{% endtrans %}
        </h2>

        <p class="text-muted mx-auto how-intro">
            {% trans %}
            Transformez les objets que vous n'utilisez plus en opportunités, sans contraintes logistiques.
            {% endtrans %}
        </p>

    </div>

    <div class="row g-4">

        <!-- Etape 1 -->
        <div class="col-md-6 col-lg-4">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">1</div>

                    <h3 class="how-title">
                        {% trans %}Publiez vos objets{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Mettez en ligne autant d'articles que vous le souhaitez avec quelques photos et une description. Donnez une seconde vie à ce qui encombre votre maison.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Etape 2 -->
        <div class="col-md-6 col-lg-4">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">2</div>

                    <h3 class="how-title">
                        {% trans %}Échangez avec les acquéreurs{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Répondez aux personnes intéressées, convenez d'un prix si nécessaire et fixez simplement un rendez-vous pour la remise des objets.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Etape 3 -->
        <div class="col-md-6 col-lg-4">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">3</div>

                    <h3 class="how-title">
                        {% trans %}Vendez sans contraintes{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Les acheteurs viennent récupérer les objets directement auprès de vous. Vous vendez plusieurs articles facilement, sans expédition ni logistique, tout en libérant de l'espace chez vous.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

</section>

<!-- AVANTAGES BROCANTE -->

<section class="advantages-section py-5">

<div class="container">

    <div class="text-center mb-5">

        <span class="section-label">
            {% trans %}Les avantages{% endtrans %}
        </span>

        <h2 class="fw-bold mt-3">
            {% trans %}Pourquoi vendre en brocante sur 𝒮araka ?{% endtrans %}
        </h2>

        <p class="text-muted advantages-intro">
            {% trans %}
            Faites de la place chez vous, donnez une nouvelle vie à vos objets et vendez simplement, sans vous compliquer la vie.
            {% endtrans %}
        </p>

    </div>

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-box-open"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Libérez de l'espace{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Désencombrez votre maison, votre garage ou votre cave en vendant les objets que vous n'utilisez plus.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-truck-loading"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Aucune logistique{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Pas d'expédition, pas de transport : les acquéreurs viennent récupérer directement leurs achats au lieu convenu.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-coins"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Vendez en toute simplicité{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Publiez plusieurs annonces, trouvez rapidement des acquéreurs près de chez vous et valorisez des objets qui dormaient dans vos placards.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

</section>

{% endblock %}