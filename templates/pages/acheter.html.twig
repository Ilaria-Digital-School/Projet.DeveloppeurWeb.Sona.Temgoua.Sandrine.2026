{% extends 'base.html.twig' %}

{% block title %}{% trans %}Acheter sur Shareo{% endtrans %}{% endblock %}

{% block body %}

<section
  class="position-relative text-white py-5"
  style="
    background-image: url('{{ asset('images/heroacheter.avif') }}');
    background-size: cover;
    background-position: center;
  "
>
  <!-- Overlay -->
  <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-50"></div>

  <!-- Contenu -->
  <div class="container min-vh-50 position-relative d-flex align-items-center justify-content-center text-center">
    <div class="col-lg-8">
      <h1 class="fw-bold mb-4">
        {% trans %}Achetez malin, achetez responsable{% endtrans %}
      </h1>

      <p class="lead mb-4">
        <strong>{% trans %}Découvrez notre marketplace de produits d'occasion vérifiés.
        Jusqu'à 70% d'économies tout en consommant mieux.{% endtrans %}</strong>
      </p>

      <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-5">
          {% trans %}Parcourir les produits{% endtrans %}
        </a>
        {# Bouton qui redirige vers la page register si visiteur non connecté #}
			{% if app.user %}
    <a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-5">
        {% trans %}Publier une annonce{% endtrans %}
    </a>
{% else %}
    <a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-5">
        {% trans %}Publier une annonce{% endtrans %}
    </a>
{% endif %}

        <a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-5">
          {% trans %}Comment ça marche ?{% endtrans %}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- PRODUITS À VENDRE -->

{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}

<!-- HOW IT WORKS -->
<section id="how-it-works" class="py-5 bg-light">
    <div class="container">
        <h2 class="fw-bold text-center text-dark mb-5">
            {% trans %}Comment acheter sur Shareo ?{% endtrans %}
        </h2>

        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="card border-0">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">1</h1>
                        <h5 class="fw-bold">{% trans %}Trouvez{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Parcourez les produits disponibles{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

 <div class="col-md-4">
                <div class="card border-0">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">2</h1>
                        <h5 class="fw-bold">{% trans %}Vérifiez{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Consultez les détails et avis sur le vendeur{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">3</h1>
                        <h5 class="fw-bold">{% trans %}Achetez{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Paiement sécurisé et livraison rapide{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- AVANTAGES -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="fw-bold text-center text-dark mb-5">
            {% trans %}Pourquoi acheter sur Shareo ?{% endtrans %}
        </h2>

        <div class="row g-4 text-center">
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-shield-alt fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">{% trans %}Produits vérifiés{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Nous demandons à nos vendeurs de vérifier leurs produits avant la vente{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-euro-sign fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">{% trans %}Économies{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Vous réalisez jusqu’à 70% moins cher que le neuf{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-leaf fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">{% trans %}Écologique{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Une consommation plus durable{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-undo fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">{% trans %}Garantie 30 jours{% endtrans %}</h5>
                        <p class="text-muted">
                            {% trans %}Satisfait ou remboursé{% endtrans %}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}