{% extends 'base.html.twig' %}

{% block title %}Acheter sur Shareo{% endblock %}

{% block body %}

<section
  class="position-relative text-white py-5"
  style="
    background-image: url('{{ asset('images/heroacheter.avif') }}');
    background-size: cover;
    background-position: center;
  "
>
  <!-- Overlay -->
  <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-50"></div>

  <!-- Contenu -->
  <div class="container min-vh-50 position-relative d-flex align-items-center justify-content-center text-center">
    <div class="col-lg-8">
      <h1 class="fw-bold mb-4">
        Achetez malin, achetez responsable
      </h1>

      <p class="lead mb-4">
        <strong>Découvrez notre marketplace de produits d’occasion vérifiés.
        Jusqu’à 70% d’économies tout en consommant mieux.</strong>
      </p>

      <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-5">
          Voir les produits
        </a>
        <a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-5">
          Comment ça marche ?
        </a>
      </div>
    </div>
  </div>
</section>

<!-- PRODUITS À VENDRE -->

{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}

<!-- HOW IT WORKS -->
<section id="how-it-works" class="py-5 bg-light">
    <div class="container">
        <h2 class="fw-bold text-center text-dark mb-5">
            Comment acheter sur Shareo ?
        </h2>

        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="card border-0">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">1</h1>
                        <h5>Trouvez</h5>
                        <p class="text-muted">
                            Parcourez les produits disponibles
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">2</h1>
                        <h5>Vérifiez</h5>
                        <p class="text-muted">
                            Consultez les détails et avis
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0">
                    <div class="card-body">
                        <h1 class="fw-bold text-success">3</h1>
                        <h5>Achetez</h5>
                        <p class="text-muted">
                            Paiement sécurisé et livraison rapide
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- AVANTAGES -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="fw-bold text-center text-dark mb-5">
            Pourquoi acheter sur Shareo ?
        </h2>

        <div class="row g-4 text-center">
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-shield-alt fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">Produits vérifiés</h5>
                        <p class="text-muted">
                            Chaque produit est inspecté avant la vente
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-euro-sign fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">Économies</h5>
                        <p class="text-muted">
                            Jusqu’à 70% moins cher que le neuf
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-leaf fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">Écologique</h5>
                        <p class="text-muted">
                            Une consommation plus durable
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <i class="fas fa-undo fa-2x text-success mb-3"></i>
                        <h5 class="fw-bold">Garantie 30 jours</h5>
                        <p class="text-muted">
                            Satisfait ou remboursé
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


{% endblock %}
