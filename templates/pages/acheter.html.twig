{% extends 'base.html.twig' %}

{% block title %}
	{% trans %}Acheter sur 𝒮araka{% endtrans %}
{% endblock %}

{% block body %}


		<section
    class="hero-page position-relative text-white"
    style="background-image: url('{{ asset('images/heroacheter.avif') }}');"
>

    <div class="hero-page-overlay"></div>

    <div class="container hero-page-content">
        <div class="col-lg-8 mx-auto text-center">

            <h1 class="hero-page-title fw-bold mb-3">
                {% trans %}Achetez malin, achetez responsable{% endtrans %}
            </h1>

            <p class="hero-page-subtitle lead mb-4 text-white fw-medium">
                {% trans %}
                    Trouvez des milliers de produits d'occasion près de chez vous
                    et réalisez jusqu'à 70% d'économies tout en favorisant une
                    consommation durable.
                {% endtrans %}
            </p>
				<!-- Boutons d'appel à l'action -->
				<div class="d-flex justify-content-center gap-2 flex-wrap">
					<a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-3">
						{% trans %}Parcourir les produits{% endtrans %}
					</a>
					{# Bouton qui redirige vers la page register si visiteur non connecté #}
					{% if app.user %}
						<a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% else %}
						<a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% endif %}

					<a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-3">
						{% trans %}Comment ça marche ?{% endtrans %}
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Liste paginée des articles de la transaction en cours-->

	{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}

	<!-- HOW IT WORKS (comment ça marche ?) -->

	<section class="py-5 bg-light">
		<div class="container">
			<h2 class="fw-bold text-center text-dark mb-5">

				{% trans %}Comment acheter sur 𝒮araka ?{% endtrans %}
			</h2>

			<div class="row g-4 text-center">
				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">

							<h2 class="fw-bold text-success">1</h2>
							<h5 class="fw-bold">{% trans %}Trouvez{% endtrans %}</h5>
							<p class="text-muted">
								{% trans %}Parcourez les articles disponibles, les plus récents apparaissent en tête de liste.{% endtrans %}
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">
							<h2 class="fw-bold text-success">2</h2>
							<h5 class="fw-bold">{% trans %}Vérifiez{% endtrans %}</h5>
							<p class="text-muted">
								{% trans %}Consultez les détails et avis sur le vendeur{% endtrans %}
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">
							<h2 class="fw-bold text-success">3</h2>
							<h5 class="fw-bold">{% trans %}Achetez{% endtrans %}</h5>
							<p class="text-muted">
								{% trans %}Contactez le vendeur et convenez ensemble des modalités de paiement et de remise.{% endtrans %}
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">
							<h2 class="fw-bold text-success">4</h2>
							<h5 class="fw-bold">{% trans %}Récupérez votre article{% endtrans %}</h5>
							<p class="text-muted">
								{% trans %}Convenez d'un lieu ou d'un mode de livraison avec le vendeur. Derrière chaque objet se cache souvent une belle rencontre.{% endtrans %}
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- AVANTAGES -->
	<section class="py-5 bg-light">
		<div class="container">
			<h2 class="fw-bold text-center text-dark mb-5">
				{% trans %}Pourquoi acheter sur 𝒮araka ?{% endtrans %}
			</h2>

			<div class="row g-4 text-center">
				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">
							<i class="fas fa-shield-alt fa-2x text-success mb-3"></i>
							<h5 class="fw-bold">{% trans %}Achat en toute transparence{% endtrans %}</h5>
							<p class="text-muted">
								{% trans %}Nous demandons à nos vendeurs de vérifier leurs produits avant la vente{% endtrans %}
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">
							<i class="fas fa-euro-sign fa-2x text-success mb-3"></i>
							<h5 class="fw-bold">{% trans %}Économique{% endtrans %}</h5>
							<p class="text-muted">
								{% trans %}Vous réalisez jusqu’à 70% moins cher que le neuf{% endtrans %}
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">
							<i class="fas fa-leaf fa-2x text-success mb-3"></i>
							<h5 class="fw-bold">{% trans %}Écologique{% endtrans %}</h5>
							<p class="text-muted">
								{% trans %}Une consommation plus durable et reduction de l'impact environnemental{% endtrans %}
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">
							<i class="fas fa-undo fa-2x text-success mb-3"></i>
							<h5 class="fw-bold">{% trans %}Échanges responsables{% endtrans %}</h5>
							<p class="text-muted">
								{% trans %}Transactions entre particuliers. Une plateforme fondée sur le partage et la confiance.{% endtrans %}
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
	<!-- Call to action -->
<section class="about-cta py-5">

    <div class="container">

        <div class="cta-card text-center">

            <div class="section-label">
                {% trans %}Rejoignez-nous{% endtrans %}
            </div>

            <h1 class="display-5 fw-bold mb-4">

                {% trans %}
                Construisons ensemble une économie plus humaine
                {% endtrans %}

            </h1>

            <p class="lead mb-4">

                {% trans %}
                Chaque objet partagé, chaque service rendu et chaque rencontre
                contribue à bâtir une communauté plus forte.
                {% endtrans %}

            </p>

            <a href="{{ path('app_register') }}"
               class="btn btn-success btn-lg rounded-pill px-5">

                {% trans %}Créer un compte{% endtrans %}

            </a>

        </div>

    </div>

</section>

{% endblock %}
