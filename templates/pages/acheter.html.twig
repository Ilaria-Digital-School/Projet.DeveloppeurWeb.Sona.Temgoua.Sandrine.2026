{% extends 'base.html.twig' %}

{% block title %}
	{% trans %}Acheter sur 𝒮araka{% endtrans %}
{% endblock %}

{% block body %}


		<section
    class="hero-page position-relative text-white"
    style="background-image: url('{{ asset('images/heroacheter.avif') }}');"
>

    <div class="hero-page-overlay"></div>

    <div class="container hero-page-content">
        <div class="col-lg-8 mx-auto text-center">

            <h1 class="hero-page-title fw-bold mb-3">
                {% trans %}Achetez malin, achetez responsable{% endtrans %}
            </h1>

            <p class="hero-page-subtitle lead mb-4 text-white fw-medium">
                {% trans %}
                    Trouvez des milliers de produits d'occasion près de chez vous
                    et réalisez jusqu'à 70% d'économies tout en favorisant une
                    consommation durable.
                {% endtrans %}
            </p>
				<!-- Boutons d'appel à l'action -->
				<div class="d-flex justify-content-center gap-2 flex-wrap">
					<a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-3">
						{% trans %}Parcourir les produits{% endtrans %}
					</a>
					{# Bouton qui redirige vers la page register si visiteur non connecté #}
					{% if app.user %}
						<a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% else %}
						<a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% endif %}

					<a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-3">
						{% trans %}Comment ça marche ?{% endtrans %}
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Liste paginée des articles de la transaction en cours-->

	{% include 'transaction/list.html.twig' with {
    articles: articles,
    pageTitle: null
} %}

<!-- HOW IT WORKS -->

<section id="how-it-works" class="how-section py-5">

<div class="container">

    <div class="text-center mb-5">

        <span class="section-label">
            {% trans %}Comment ça marche{% endtrans %}
        </span>

        <h2 class="fw-bold mt-3">
            {% trans %}Comment acheter sur 𝒮araka ?{% endtrans %}
        </h2>

        <p class="text-muted mx-auto how-intro">
            {% trans %}
            Trouvez facilement des articles près de chez vous, échangez avec le vendeur et achetez en toute simplicité.
            {% endtrans %}
        </p>

    </div>

    <div class="row g-4">

        <!-- Étape 1 -->
        <div class="col-md-6 col-lg-3">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">
                        1
                    </div>

                    <h3 class="how-title">
                        {% trans %}Explorez les annonces{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Parcourez les annonces disponibles et découvrez des milliers d'articles proposés près de chez vous.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Étape 2 -->
        <div class="col-md-6 col-lg-3">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">
                        2
                    </div>

                    <h3 class="how-title">
                        {% trans %}Contactez le vendeur{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Utilisez la messagerie Saraka pour poser vos questions, confirmer la disponibilité et organiser la transaction.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Étape 3 -->
        <div class="col-md-6 col-lg-3">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">
                        3
                    </div>

                    <h3 class="how-title">
                        {% trans %}Finalisez votre achat{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Convenez ensemble du prix, du paiement et du lieu de remise en toute confiance.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Étape 4 -->
        <div class="col-md-6 col-lg-3">

            <div class="card how-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="step-circle">
                        4
                    </div>

                    <h3 class="how-title">
                        {% trans %}Profitez de votre achat{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Récupérez votre article, réalisez des économies et offrez une seconde vie à un objet de qualité.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

</section>



<!-- AVANTAGES -->

<section class="advantages-section py-5">

<div class="container">

    <div class="text-center mb-5">

        <span class="section-label">
            {% trans %}Les avantages{% endtrans %}
        </span>

        <h2 class="fw-bold mt-3">
            {% trans %}Pourquoi acheter sur 𝒮araka ?{% endtrans %}
        </h2>

        <p class="text-muted advantages-intro">
            {% trans %}
            Acheter sur Saraka, c'est économiser, consommer autrement et soutenir une économie locale plus responsable.
            {% endtrans %}
        </p>

    </div>

    <div class="row g-4">

        <!-- Carte 1 -->
        <div class="col-md-6 col-lg-3">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-piggy-bank"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Faites des économies{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Achetez des articles de qualité à des prix souvent bien inférieurs au neuf.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Carte 2 -->
        <div class="col-md-6 col-lg-3">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-search"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Dénichez des pépites{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Découvrez des objets uniques, rares ou introuvables dans le commerce traditionnel.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Carte 3 -->
        <div class="col-md-6 col-lg-3">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-leaf"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Consommez responsable{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Donnez une seconde vie aux objets et contribuez à réduire le gaspillage.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

        <!-- Carte 4 -->
        <div class="col-md-6 col-lg-3">

            <div class="card advantage-card border-0 h-100">

                <div class="card-body text-center">

                    <div class="advantage-circle">
                        <i class="fas fa-handshake"></i>
                    </div>

                    <h3 class="advantage-title">
                        {% trans %}Échanges de proximité{% endtrans %}
                    </h3>

                    <p class="text-muted mb-0">
                        {% trans %}
                        Rencontrez des vendeurs près de chez vous et profitez d'échanges simples, humains et en toute confiance.
                        {% endtrans %}
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

</section>

{% endblock %}
