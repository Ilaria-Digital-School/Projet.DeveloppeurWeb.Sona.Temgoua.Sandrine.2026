{% extends 'base.html.twig' %}

{% block title %}
	{% trans %}Alimentaires sur 𝒮araka{% endtrans %}
{% endblock %}

{% block body %}

	<!-- HERO -->

	<section class="hero-page position-relative text-white" style="background-image: url('{{ asset('images/alimentairehero.png') }}');">

		<div class="hero-page-overlay"></div>

		<div class="container hero-page-content">
			<div class="col-lg-8 mx-auto text-center">

				<h1 class="hero-page-title fw-bold mb-3">
					{% trans %}Le plat du voisin a toujours quelque chose à raconter{% endtrans %}
				</h1>

				<p class="hero-page-subtitle lead mb-4 text-white fw-medium">
					{% trans %}
					Achetez ou faites découvrir des produits locaux, des plats maison, 
					                 ainsi que les récoltes de votre potager ou les surplus de votre cuisine. 
					                 Chaque saveur raconte une histoire de partage, d'amour, de proximité et de solidarité.
					{% endtrans %}
				</p>

				<!-- Boutons CTA -->
				<div class="d-flex justify-content-center gap-2 flex-wrap">

					<a href="#products" class="btn btn-warning btn-lg text-dark rounded-pill px-3">
						{% trans %}Découvrir les produits{% endtrans %}
					</a>

					{% if app.user %}
						<a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% else %}
						<a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-3">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% endif %}

					<a href="#how-it-works" class="btn btn-outline-light btn-lg rounded-pill px-3">
						{% trans %}Comment ça marche ?{% endtrans %}
					</a>

				</div>

			</div>

		</div>

	</section>


	<!-- PRODUITS -->

	<div id="products">

		{% include 'transaction/list.html.twig' with {
        articles: articles,
        pageTitle: null
    } %}

	</div>

	<!-- COMMENT ÇA MARCHE -->

	<section id="how-it-works" class="py-5 bg-light">

		<div class="container">

			<h2 class="fw-bold text-center text-dark mb-5">
				{% trans %}Comment échanger des produits alimentaires sur 𝒮araka ?{% endtrans %}
			</h2>

			<div class="row g-4 text-center">

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">

							<h2 class="fw-bold text-success">1</h2>

							<h5 class="fw-bold">
								{% trans %}Découvrez{% endtrans %}
							</h5>

							<p class="text-muted">
								{% trans %}
								Parcourez les produits disponibles, les publications les plus récentes apparaissent en premier.
								{% endtrans %}
							</p>

						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">

							<h2 class="fw-bold text-success">2</h2>

							<h5 class="fw-bold">
								{% trans %}Informez-vous{% endtrans %}
							</h5>

							<p class="text-muted">
								{% trans %}
								Consultez les informations fournies concernant l'origine,
								                            la préparation ou les conditions de conservation du produit.
								{% endtrans %}
							</p>

						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">

							<h2 class="fw-bold text-success">3</h2>

							<h5 class="fw-bold">
								{% trans %}Échangez{% endtrans %}
							</h5>

							<p class="text-muted">
								{% trans %}
								Contactez le vendeur afin de convenir librement des modalités
								                            de remise, de livraison ou de participation.
								{% endtrans %}
							</p>

						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">

							<h2 class="fw-bold text-success">4</h2>

							<h5 class="fw-bold">
								{% trans %}Partagez{% endtrans %}
							</h5>

							<p class="text-muted">
								{% trans %}
								Récupérez votre produit et participez à une consommation plus locale,
								                            plus responsable et plus humaine.
								{% endtrans %}
							</p>

						</div>
					</div>
				</div>

			</div>

		</div>

	</section>

	<!-- AVANTAGES -->

	<section class="py-5 bg-light">

		<div class="container">

			<h2 class="fw-bold text-center text-dark mb-5">
				{% trans %}Pourquoi partager des produits alimentaires sur 𝒮araka ?{% endtrans %}
			</h2>

			<div class="row g-4 text-center">

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">

							<i class="fas fa-seedling fa-2x text-success mb-3"></i>

							<h5 class="fw-bold">
								{% trans %}Moins de gaspillage{% endtrans %}
							</h5>

							<p class="text-muted">
								{% trans %}
								Valorisez vos surplus alimentaires et donnez une nouvelle utilité aux ressources disponibles.
								{% endtrans %}
							</p>

						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">

							<i class="fas fa-map-marker-alt fa-2x text-success mb-3"></i>

							<h5 class="fw-bold">
								{% trans %}Produits locaux{% endtrans %}
							</h5>

							<p class="text-muted">
								{% trans %}
								Découvrez les récoltes, préparations artisanales et productions proposées près de chez vous.
								{% endtrans %}
							</p>

						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">

							<i class="fas fa-leaf fa-2x text-success mb-3"></i>

							<h5 class="fw-bold">
								{% trans %}Consommation responsable{% endtrans %}
							</h5>

							<p class="text-muted">
								{% trans %}
								Favorisez les circuits courts et une utilisation plus intelligente des ressources alimentaires.
								{% endtrans %}
							</p>

						</div>
					</div>
				</div>

				<div class="col-md-3">
					<div class="card h-100 border-0 shadow-sm">
						<div class="card-body">

							<i class="fas fa-hands-helping fa-2x text-success mb-3"></i>

							<h5 class="fw-bold">
								{% trans %}Convivialité{% endtrans %}
							</h5>

							<p class="text-muted">
								{% trans %}
								Chaque échange est aussi l'occasion de rencontrer des personnes
								                            partageant les mêmes valeurs de solidarité et de confiance.
								{% endtrans %}
							</p>

						</div>
					</div>
				</div>

			</div>

		</div>

	</section>

	<!-- Call to action -->
<section class="about-cta py-5">

    <div class="container">

        <div class="cta-card text-center">

            <div class="section-label">
                {% trans %}Rejoignez-nous{% endtrans %}
            </div>

            <h1 class="display-5 fw-bold mb-4">

                {% trans %}
                Construisons ensemble une économie plus humaine
                {% endtrans %}

            </h1>

            <p class="lead mb-4">

                {% trans %}
                Chaque objet partagé, chaque service rendu et chaque rencontre
                contribue à bâtir une communauté plus forte.
                {% endtrans %}

            </p>

            <a href="{{ path('app_register') }}"
               class="btn btn-success btn-lg rounded-pill px-5">

                {% trans %}Créer un compte{% endtrans %}

            </a>

        </div>

    </div>

</section>

{% endblock %}
