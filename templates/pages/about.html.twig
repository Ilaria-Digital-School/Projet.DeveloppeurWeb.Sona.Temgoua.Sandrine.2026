{% extends 'base.html.twig' %}

{% block title %}
	{% trans %}À propos de 𝒮araka{% endtrans %}
{% endblock %}

{% block body %}


<section class="hero-about text-white">

    <div class="container-fluid h-100">
        <div class="row g-0 h-100">

            <!-- TEXTE -->
            <div class="col-lg-5 hero-content d-flex align-items-center">

                <div class="hero-text px-4 px-lg-5 py-5">

                    <div class="hero-label mb-3">
                        {% trans %}À propos de <strong><span>𝒮</span></strong>araka{% endtrans %}
                    </div>

                    <h1 class="display-2 fw-bold hero-title mb-4">
                        {% trans %}Notre{% endtrans %}
                        <span class="text-success">{% trans %}Vision{% endtrans %}
                    </h1>

                    <blockquote class="hero-slogan mb-4">
                        {% trans %}
                        Donner une seconde vie aux ressources,
                        une première place à l'humain.
                        {% endtrans %}
                    </blockquote>

                    <div class="vision-card">

                        <p class="vision-text mb-0">

                            <span class="s-letter">𝒮</span>araka est née d'une conviction simple :
                            ce qui a encore de la valeur mérite une seconde vie.

                            <br><br>

                            Chaque jour, des objets utilisables sont abandonnés,
                            des ressources sont gaspillées et des opportunités
                            de solidarité passent inaperçues.

                            <br><br>

                            Nous imaginons une société où le partage devient un réflexe,
                            où chacun peut facilement donner, échanger, vendre ou transmettre
                            ce dont il n'a plus besoin à ceux qui en ont l'utilité.

                            <br><br>

                            Plus qu'une plateforme, Saraka est un mouvement citoyen
                            qui encourage une consommation plus responsable,
                            réduit le gaspillage et favorise l'entraide de proximité.

                        </p>

                    </div>

                </div>

            </div>

            <!-- IMAGE -->
            <div class="col-lg-7 hero-image"></div>

        </div>
    </div>

</section>

<!-- Notre équipe -->

<section class="team-section py-5">

    <div class="container">

        <div class="text-center mb-5">

            <h1 class="display-4 fw-bold section-title">
                {% trans %}Les personnes derrière{% endtrans %}
                <span class="text-success">Saraka</span>
            </h1>

            <p class="section-subtitle mx-auto">
                {% trans %}
                Derrière Saraka se trouvent des personnes convaincues qu'une économie
                plus humaine, plus locale et plus durable est possible.
                {% endtrans %}
            </p>

        </div>

        <div class="row g-4">

            <div class="col-md-6 col-lg-3">
                <div class="team-card">

                    <img src="{{ asset('images/Sandrine.jpg') }}"
                         class="team-img"
                         alt="Sandrine">

                    <div class="team-body">

                        <h5 class="fw-bold mb-1">
                            Sandrine
                        </h5>

                        <p class="team-role">
                            {% trans %}Fondatrice & Développeuse{% endtrans %}
                        </p>

                        <p class="team-description">
                            {% trans %}
                            Porteuse de la vision et responsable du développement de la plateforme.
                            {% endtrans %}
                        </p>

                    </div>

                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="team-card">

                    <img src="{{ asset('images/Christian.jpg') }}"
                         class="team-img"
                         alt="Christian">

                    <div class="team-body">

                        <h5 class="fw-bold mb-1">Christian</h5>

                        <p class="team-role">
                            {% trans %}Administrateur{% endtrans %}
                        </p>

                        <p class="team-description">
                            {% trans %}
                            Veille au bon fonctionnement et à l'organisation de la plateforme.
                            {% endtrans %}
                        </p>

                    </div>

                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="team-card">

                    <img src="{{ asset('images/imgSofie.png') }}"
                         class="team-img"
                         alt="Sophie">

                    <div class="team-body">

                        <h5 class="fw-bold mb-1">Sophie</h5>

                        <p class="team-role">
                            {% trans %}Relation client{% endtrans %}
                        </p>

                        <p class="team-description">
                            {% trans %}
                            Accompagne les membres et favorise une expérience utilisateur de qualité.
                            {% endtrans %}
                        </p>

                    </div>

                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="team-card">

                    <img src="{{ asset('images/David.jpg') }}"
                         class="team-img"
                         alt="David">

                    <div class="team-body">

                        <h5 class="fw-bold mb-1">David</h5>

                        <p class="team-role">
                            {% trans %}Chef de projet{% endtrans %}
                        </p>

                        <p class="team-description">
                            {% trans %}
                            Coordonne les initiatives et accompagne la croissance du projet.
                            {% endtrans %}
                        </p>

                    </div>

                </div>
            </div>

        </div>

    </div>

</section>

<!-- Nos valeurs -->
<section class="values-section py-5">

    <div class="container">

        <div class="text-center mb-5">

            <h1 class="display-4 fw-bold section-title">
                {% trans %}Ce qui nous{% endtrans %}
                <span class="text-success">{% trans %}rassemble{% endtrans %}</span>
            </h1>

            <p class="section-subtitle mx-auto">
                {% trans %}
                Des valeurs qui donnent du sens à chaque échange et à chaque partage.
                {% endtrans %}
            </p>

        </div>

        <div class="row g-4">

            <div class="col-md-6 col-lg-3">
                <div class="feature-card">

                    <h5>Économie</h5>

                    <p>
                        {% trans %}
                        Permettre à chacun d'accéder à des biens et services à moindre coût.
                        {% endtrans %}
                    </p>

                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="feature-card">

                    <h5>Durabilité</h5>

                    <p>
                        {% trans %}
                        Réduire le gaspillage et donner une seconde vie aux ressources.
                        {% endtrans %}
                    </p>

                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="feature-card">

                    <h5>Solidarité</h5>

                    <p>
                        {% trans %}
                        Favoriser l'entraide et les échanges de proximité.
                        {% endtrans %}
                    </p>

                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="feature-card">

                    <h5>Innovation</h5>

                    <p>
                        {% trans %}
                        Utiliser la technologie pour rapprocher les personnes.
                        {% endtrans %}
                    </p>

                </div>
            </div>

        </div>

    </div>

</section>

{% endblock %}