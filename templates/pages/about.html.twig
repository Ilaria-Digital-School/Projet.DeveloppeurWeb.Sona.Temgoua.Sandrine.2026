{% extends 'base.html.twig' %}

{% block title %}
	{% trans %}À propos de saraka{% endtrans %}
{% endblock %}

{% block body %}

	<!-- Hero About -->
	<section
		class="position-relative text-white py-4" style="
												    background-image: url('{{ asset('images/partageheroabout.png') }}');
												    background-size: cover;
												    background-position: center;
													height: 75vh;
												">

		<!-- Overlay -->
		<div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-50"></div>

		<!-- Contenu -->

		<div class="container min-vh-50 position-relative d-flex align-items-center justify-content-center text-center">

<div class="col-lg-8">

				<h1 class="display-3 fw-bold hero-title mb-2" style="font-family: 'Playfair Display', serif; text-shadow: 2px 2px 4px rgba(0,0,0,0.7);">
					{% trans %}Notre{% endtrans %}
					<span class="text-success">{% trans %}Vision{% endtrans %}
					</h1>

					<p class="vision-text text-center text-light mx-auto">
						<strong>
							<span>𝒮</span>araka</strong>
						{% trans %}
						est né d'une vision simple: révolutionner notre manière de consommer.
						    Un monde où le partage est au cœur de notre quotidien,
						    où chaque objet trouve une seconde vie,
						    et où les liens humains se tissent à travers la générosité et la confiance.
						{% endtrans %}
					</p>

					<!-- valeurs badges -->
					<p class="text-center mt-4 fs-5 valeurs">

						<span class="badge rounded-pill bg-success fs-6 px-3 py-2 valeur v1">
							🟢
							{% trans %}Partager{% endtrans %}
						</span>

						<span class="mx-2 text-muted separator v2">✦</span>

						<span class="badge rounded-pill bg-warning text-dark fs-6 px-3 py-2 valeur v3">
							🟡
							{% trans %}Réutiliser{% endtrans %}
						</span>

						<span class="mx-2 text-muted separator v4">✦</span>

						<span class="badge rounded-pill bg-primary fs-6 px-3 py-2 valeur v5">
							🔵
							{% trans %}Créer des liens{% endtrans %}
						</span>

					</p>

				</div>
			</div>

		</section>

		<!-- team section -->

		<section class="pt-2 pb-5 team-section">
			<div class="container text-center">

				<h2 class="display-3 fw-bold hero-title mb-3" style="font-family: 'Playfair Display', serif; text-shadow: 2px 2px 4px rgba(0,0,0,0.7);">
					{% trans %}Notre{% endtrans %}
					<span class="text-success">{% trans %}Équipe{% endtrans %}</span>
				</h2>
				<p class="vision-text text-center text-dark mx-auto">
					<strong>
						{% trans %}
						Une équipe qui, à travers son propre parcours, s’est reconnue dans notre vision et œuvre chaque jour pour rendre le partage accessible à tous.{% endtrans %}</strong>
				</p>
				<div
					class="row g-4">

					<!-- Sandrine -->
					<div class="col-12 col-sm-6 col-md-3">
						<div class="team-card p-4 shadow-sm" style="background-image: url('{{ asset('images/Sandrine.jpg') }}');">

							<div class="overlay"></div>

							<div class="team-content text-center">
								<img src="{{ asset('images/Sandrine.jpg') }}" class="rounded-circle mb-3 team-img" alt="Sandrine">
								<h5 class="fw-bold text-white">Sandrine</h5>
								<p class="text-success small mb-2">{% trans %}Fondatrice & Développeuse{% endtrans %}</p>

								<div class="social-icons">
									<a href="#">
										<i class="fab fa-facebook"></i>
									</a>
									<a href="#">
										<i class="bi bi-twitter"></i>
									</a>
									<a href="#">
										<i class="bi bi-github"></i>
									</a>

								</div>
							</div>

						</div>
					</div>

					<!-- Christian -->
					<div class="col-12 col-sm-6 col-md-3">
						<div class="team-card p-4 shadow-sm" style="background-image: url('{{ asset('images/Christian.jpg') }}');">

							<div class="overlay"></div>

							<div class="team-content text-center">
								<img src="{{ asset('images/Christian.jpg') }}" class="rounded-circle mb-3 team-img" alt="Christian">
								<h5 class="fw-bold text-white">Christian</h5>
								<p class="text-primary small mb-2">{% trans %}Administrateur virtuel{% endtrans %}</p>

								<div class="social-icons">
									<a href="#">
										<i class="bi bi-linkedin"></i>
									</a>
									<a href="#">
										<i class="bi bi-twitter"></i>
									</a>
									<a href="#">
										<i class="bi bi-instagram"></i>
									</a>
								</div>
							</div>

						</div>
					</div>

					<!-- Sophie -->
					<div class="col-12 col-sm-6 col-md-3">
						<div class="team-card p-4 shadow-sm" style="background-image: url('{{ asset('images/imgSofie.png') }}');">

							<div class="overlay"></div>

							<div class="team-content text-center">
								<img src="{{ asset('images/imgSofie.png') }}" class="rounded-circle mb-3 team-img" alt="Sophie">
								<h5 class="fw-bold text-white">Sophie</h5>
								<p class="text-warning small mb-2">{% trans %}Relation client{% endtrans %}</p>

								<div class="social-icons">
									<a href="https://linkedin.com/in/tonprofil" target="_blank" rel="noopener noreferrer">
										<i class="bi bi-linkedin"></i>
									</a>
									<a href="https://twitter.com/tonprofil" target="_blank" rel="noopener noreferrer">
										<i class="bi bi-twitter"></i>
									</a>
									<a href="https://instagram.com/tonprofil" target="_blank" rel="noopener noreferrer">
										<i class="bi bi-instagram"></i>
									</a>
								</div>
							</div>

						</div>
					</div>

					<!-- David -->
					<div class="col-12 col-sm-6 col-md-3">
						<div class="team-card p-4 shadow-sm" style="background-image: url('{{ asset('images/David.jpg') }}');">

							<div class="overlay"></div>

							<div class="team-content text-center">
								<img src="{{ asset('images/David.jpg') }}" class="rounded-circle mb-3 team-img" alt="David">
								<h5 class="fw-bold text-white">David</h5>
								<p class="text-danger small mb-2">{% trans %}Chef de projet{% endtrans %}</p>

								<div class="social-icons">
									<a href="#">
										<i class="bi bi-linkedin"></i>
									</a>
									<a href="#">
										<i class="bi bi-twitter"></i>
									</a>
									<a href="#">
										<i class="bi bi-instagram"></i>
									</a>
								</div>
							</div>

						</div>
					</div>

				</div>
			</div>
		</section>
	</div>

	<!-- Section Features -->
	<section class="py-5">
		<div class="container text-center">
			<h2 class="display-3 fw-bold hero-title mb-3" style="font-family: 'Playfair Display', serif; text-shadow: 2px 2px 4px rgba(0,0,0,0.7);">
				{% trans %}Nos{% endtrans %}
				<span class="text-success">{% trans %}Valeurs{% endtrans %}</span>
			</h2>
			<p class="vision-text text-center text-dark mx-auto">

				<strong>
					{% trans %}Des valeurs qui nous rassemblent et donnent une âme à tout ce que nous construisons.{% endtrans %}
				</strong>
			</p>
			<div class="row g-4">
				<div class="col-12 col-sm-6 col-md-3 d-flex">
					<div class="card feature-card border-0 shadow-sm flex-fill text-center p-4">
						<div class="display-4 mb-3">💰</div>
						<h5 class="fw-bold">{% trans %}Économique{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Louez ou achetez au meilleur prix, sans gaspillage.{% endtrans %}
						</p>
					</div>
				</div>

				<div class="col-12 col-sm-6 col-md-3 d-flex">
					<div class="card feature-card border-0 shadow-sm flex-fill text-center p-4">
						<div class="display-4 mb-3">🌱</div>
						<h5 class="fw-bold">{% trans %}Écologie{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Encourager le partage pour réduire la surconsommation et préserver notre environnement.{% endtrans %}
						</p>
					</div>
				</div>

				<div class="col-12 col-sm-6 col-md-3 d-flex">
					<div class="card feature-card border-0 shadow-sm flex-fill text-center p-4">
						<div class="display-4 mb-3">🤝</div>
						<h5 class="fw-bold">{% trans %}Entraide{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Créer une communauté basée sur l’entraide et la confiance.{% endtrans %}
						</p>
					</div>
				</div>

				<div class="col-12 col-sm-6 col-md-3 d-flex">
					<div class="card feature-card border-0 shadow-sm flex-fill text-center p-4">
						<div class="display-4 mb-3">💡</div>
						<h5 class="fw-bold">{% trans %}Innovation{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Proposer des solutions simples et modernes pour consommer autrement.{% endtrans %}
						</p>
					</div>
				</div>
			</p>
		</div>
	</div>
</section>{% endblock %}
