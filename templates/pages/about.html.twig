
{% extends 'base.html.twig' %}

{% block title %}{% trans %}À propos de Shareo{% endtrans %}
{% endblock %}

{% block body %}

	<!-- Hero About -->
	<section class="about-hero py-5 text-center">
		<div class="container">

			<h1 class="display-5 fw-bold hero-title">
				{% trans %}Nos{% endtrans %}
				<span class="text-success">{% trans %}valeurs{% endtrans %}</span>
			</h1>

			<p class="lead mt-4 hero-text">
				<strong>
					{% trans %}Shareo est né d’une conviction simple : révolutionner la manière dont nous consommons. 
					        Nous croyons fermement que le partage est la clé pour construire un avenir plus durable, plus solidaire et plus innovant.
					   Notre mission : permettre à chacun de donner, louer ou acheter facilement, tout en réduisant le gaspillage et en créant des liens.{% endtrans %}
				</strong>
			</p>

			<!-- valeurs badges -->
			<p class="text-center mt-4 fs-5 valeurs">

				<span class="badge rounded-pill bg-success fs-6 px-3 py-2 valeur v1">
					🟢 {% trans %}Partager{% endtrans %}
				</span>

				<span class="mx-2 text-muted separator v2">✦</span>

				<span class="badge rounded-pill bg-warning text-dark fs-6 px-3 py-2 valeur v3">
					🟡 {% trans %}Réutiliser{% endtrans %}
				</span>

				<span class="mx-2 text-muted separator v4">✦</span>

				<span class="badge rounded-pill bg-primary fs-6 px-3 py-2 valeur v5">
					🔵 {% trans %}Créer des liens{% endtrans %}
				</span>

			</p>
		</div>
	</section>

	<!-- Vision -->
	<section class="py-5">
		<div class="container">
			<div class="row g-4">

				<div class="col-md-4 d-flex">
					<div class="card shadow-sm flex-fill text-center p-4">
						<div class="display-4 mb-3">🌱</div>
						<h5 class="fw-bold">{% trans %}Écologie{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Encourager le partage pour réduire la surconsommation
							                        et préserver notre environnement.{% endtrans %}
						</p>
					</div>
				</div>

				<div class="col-md-4 d-flex">
					<div class="card shadow-sm flex-fill text-center p-4">
						<div class="display-4 mb-3">🤝</div>
						<h5 class="fw-bold">{% trans %}Entraide{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Créer une communauté basée sur l’entraide
							                        et la confiance.{% endtrans %}
						</p>
					</div>
				</div>

				<div class="col-md-4 d-flex">
					<div class="card shadow-sm flex-fill text-center p-4">
						<div class="display-4 mb-3">💡</div>
						<h5 class="fw-bold">{% trans %}Innovation{% endtrans %}</h5>
						<p class="text-muted">
							{% trans %}Proposer des solutions simples et modernes
							                        pour consommer autrement.{% endtrans %}
						</p>
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- FEATURES -->
	<section class="features py-5 bg-light">
		<div class="container">
			<div class="row text-center">

				<div class="col-md-4 mb-4">
					<div class="feature-box p-4 h-100">
						<h5 class="fw-bold">🌱 {% trans %}Écologique{% endtrans %}</h5>
						<p class="fs-6">
							{% trans %}Réduisez votre impact environnemental en partageant des produits.{% endtrans %}
						</p>
					</div>
				</div>
				<div class="col-md-4 mb-4">
					<div class="feature-box p-4 h-100">
						<h5 class="fw-bold">🤝 {% trans %}Collaboratif{% endtrans %}</h5>
						<p class="fs-6">
							{% trans %}Une communauté basée sur la confiance et le partage.{% endtrans %}
						</p>
					</div>
				</div>
				<div class="col-md-4 mb-4">
					<div class="feature-box p-4 h-100">
						<h5 class="fw-bold">💰 {% trans %}Économique{% endtrans %}</h5>
						<p class="fs-6">
							{% trans %}Louez ou achetez au meilleur prix, sans gaspillage.{% endtrans %}
						</p>
					</div>
				</div>

			</div>
		</div>
	</section>

{% endblock %}