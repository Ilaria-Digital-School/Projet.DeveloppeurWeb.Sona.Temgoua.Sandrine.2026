{% extends 'base.html.twig' %}

{% block title %}{% trans %}Liste auteurs{% endtrans %}{% endblock %}

{% block body %}

<div class="container my-5">

    <h1 class="mb-4 text-success fw-bold">{% trans %}Liste auteurs{% endtrans %}</h1>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle shadow-sm border rounded">
            <thead class="table-success">
                <tr>
                    <th>N°</th>
                    <th>{% trans %}Noms{% endtrans %}</th>
                    <th>{% trans %}Minibio{% endtrans %}</th>
                    <th>{% trans %}actions{% endtrans %}</th>
                </tr>
            </thead>
            <tbody>
            {% set i = 1 %}
            {% for author in authors %}
                <tr>
                    <td class="fw-semibold">{{ i }}</td>

                    <td class="fw-semibold text-success">
                        {{ author.firstName }}
                        {{ author.lastName }} 
                    </td>

                    <td style="max-width:300px;" class="text-truncate">
                        {{ author.minibio }}
                    </td>

                    <td>
                        <a href="{{ path('app_show_author', {'slug': author.slug}) }}"
                           class="btn btn-sm btn-outline-success me-2">
                            {% trans %}Afficher{% endtrans %}
                        </a>

                        {# <a href="{{ path('app_author_edit', {'id': author.id}) }}" #}
                        <a href="javascript:void(0);"
                           class="btn btn-sm btn-success">
                            {% trans %}Editer{% endtrans %}
                        </a>

                        {#{{ include("author/_delete_form.html.twig") }}#}
                    </td>
                </tr>
                {% set i = i + 1 %}
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">
                        {% trans %}Pas d'enregistrements{% endtrans %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# <a href="{{ path('app_author_new') }}" class="btn btn-success mt-3">#}
    <a href="javascript:void(0);" class="btn btn-success mt-3">
        {% trans %}Créer un nouvel auteur{% endtrans %}
    </a>

</div>

{% endblock %}