{% extends 'base.html.twig' %}

{% block title %}{% trans %}Créer un auteur{% endtrans %}{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-success text-white rounded-top-4">
                    <h1 class="h3 mb-0">{% trans %}Créer un nouvel auteur{% endtrans %}</h1>
                </div>

                <div class="card-body p-4">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="mb-3">
                        {{ form_label(form.firstName, 'Prénom', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.firstName, {'attr': {'class': 'form-control' ~ (form.firstName.vars.valid ? '' : ' is-invalid')}}) }}
                        {{ form_errors(form.firstName) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.lastName, 'Nom', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.lastName, {'attr': {'class': 'form-control' ~ (form.lastName.vars.valid ? '' : ' is-invalid')}}) }}
                        {{ form_errors(form.lastName) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.minibio, 'Mini-biographie', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.minibio, {'attr': {'class': 'form-control' ~ (form.minibio.vars.valid ? '' : ' is-invalid'), 'rows': 4}}) }}
                        <div class="form-text">{% trans %}Courte présentation de l'auteur (max 255 caractères).{% endtrans %}</div>
                        {{ form_errors(form.minibio) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.slug, 'Slug (optionnel)', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.slug, {'attr': {'class': 'form-control' ~ (form.slug.vars.valid ? '' : ' is-invalid'), 'placeholder': 'slug-personnalise'}}) }}
                        <div class="form-text">{% trans %}Laissez vide pour une génération automatique à partir du nom.{% endtrans %}</div>
                        {{ form_errors(form.slug) }}
                    </div>

                    {# Ajoute ici d'autres champs si nécessaire, par ex. "photo" #}

                    <div class="d-flex justify-content-between mt-4 pt-2">
                        <a href="{{ path('app_author_index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> {% trans %}Retour à la liste{% endtrans %}
                        </a>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-save"></i> {% trans %}Enregistrer{% endtrans %}
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}