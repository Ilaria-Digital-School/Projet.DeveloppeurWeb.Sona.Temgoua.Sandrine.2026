<form method="post"
      action="javascript:void(0);"
      onsubmit="return confirm('Are you sure you want to delete this item?');"
      class="d-inline">

    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ author.id) }}">

    <button class="btn btn-danger">
        🗑 Delete
    </button>
</form>