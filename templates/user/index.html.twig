{% extends 'base.html.twig' %}

{% block title %}User index{% endblock %}

{% block body %}

<div class="container my-5">

    <h1 class="mb-4 text-success fw-bold">User index</h1>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle shadow-sm border rounded">
            <thead class="table-success">
                <tr>
                    <th>Id</th>
                    <th>Roles</th>
                    <th>Email</th>
                    <th>Firstname</th>
                    <th>Lastname</th>
                    <th>CreatedAt</th>
                    <th>UpdatedAt</th>
                    <th>IsVerified</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr>
                    <td class="fw-semibold">{{ user.id }}</td>

                    <td>
                        <span class="badge bg-secondary">
                            {{ user.roles ? user.roles|json_encode : '' }}
                        </span>
                    </td>

                    <td class="fw-semibold text-success">
                        {{ user.email }}
                    </td>

                    <td>{{ user.firstname }}</td>
                    <td>{{ user.lastname }}</td>

                    <td class="text-muted small">
                        {{ user.createdAt ? user.createdAt|date('Y-m-d H:i:s') : '' }}
                    </td>

                    <td class="text-muted small">
                        {{ user.updatedAt ? user.updatedAt|date('Y-m-d H:i:s') : '' }}
                    </td>

                    <td>
                        {% if user.isVerified %}
                            <span class="badge bg-success">Yes</span>
                        {% else %}
                            <span class="badge bg-secondary">No</span>
                        {% endif %}
                    </td>

                    <td>
                        <a href="{{ path('app_user_show', {'id': user.id}) }}"
                           class="btn btn-sm btn-outline-success me-2">
                            show
                        </a>

                        <a href="{{ path('app_user_edit', {'id': user.id}) }}"
                           class="btn btn-sm btn-success">
                            edit
                        </a>

                        {{ include('user/_delete_form.html.twig') }}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="10" class="text-center text-muted py-4">
                        no records found
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <a href="{{ path('app_user_new') }}"
       class="btn btn-success mt-3">
       Create new
    </a>

</div>

{% endblock %}
