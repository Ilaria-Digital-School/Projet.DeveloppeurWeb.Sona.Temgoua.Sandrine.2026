<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<meta name="description" content="Shareo est une plateforme innovante de location et d'achat de produits. Économique, écologique et pratique.">
		<meta name="author" content="Sona Temgoua">
		<meta name="keywords" content="location, achat, partage, économie, écologie, produits, plateforme">

		<title>
			{% block title %}Shareo||Plateforme de location & d'achat
			{% endblock %}
		</title>

		<!-- Favicon avec fallback pour différents formats -->
		<link rel="apple-touch-icon" sizes="180x180" href="{{ asset('images/favicon/apple-touch-icon.png') }}">
		<link rel="icon" type="image/png" sizes="32x32" href="{{ asset('images/favicon/favicon-32x32.png') }}">
		<link rel="icon" type="image/png" sizes="16x16" href="{{ asset('images/favicon/favicon-16x16.png') }}">
		<link rel="manifest" href="{{ asset('images/favicon/site.webmanifest') }}">
		

		{% block stylesheets %}
			<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
			<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
			{{ encore_entry_link_tags('app') }}
		{% endblock %}

		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
		{% endblock %}
	</head>
	<body>
		{% block header %}
			{% include 'partials/header.html.twig' %}
		{% endblock %}

		{% block flash_messages %}
			{% include 'partials/flash_message.html.twig' %}
		{% endblock %}

		{% block body %}{% endblock %}

		{% block footer %}
			{% include 'partials/footer.html.twig' %}
		{% endblock %}
	</body>
</html>
