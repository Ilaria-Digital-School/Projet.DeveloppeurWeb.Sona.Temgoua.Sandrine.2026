{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}

  <h1>Welcome to the Home Page</h1>

  <div class="container mt-4">
    <div class="row">
      {% for article in articles %}
        <div class="col-md-3 mb-3 d-flex">
          <div class="card shadow-sm d-flex flex-column h-100" style="width: 14rem;">

            {% if article.image %}
              <img src="{{ asset('uploads/images/' ~ article.image) }}" class="card-img-top img-fluid" alt="{{ article.title }}">
            {% else %}
              <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height:150px;">
                <span class="text-muted">No image</span>
              </div>
            {% endif %}

            <div class="card-body flex-grow-1">
              <h6 class="card-title">{{ article.title }}</h6>
              {% if article.summary %}
                <p class="card-text small">{{ article.summary|slice(0, 30) }}...</p>
              {% endif %}
              <p class="card-text small">{{ article.content|slice(0, 50) }}...</p>
            </div>

            <div class="card-footer mt-auto text-center">
              <a href="{{ path('app_article_detail', {'id': article.id}) }}" class="btn btn-primary w-100">Go somewhere</a>
            </div>
          </div>
        </div>
      {% else %}
        <div class="col-12">
          <div class="alert alert-warning text-center">No article found</div>
        </div>
      {% endfor %}
    </div>
  </div>

{% endblock %}