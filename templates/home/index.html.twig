{# On hérite du template principal du site pour garder la même structure (header, footer, etc.) #}
{% extends 'base.html.twig' %}

{# Bloc qui définit le titre de la page dans l'onglet du navigateur #}
{% block title %}
	{% trans %}𝒮araka|Plateforme de location et d'achat{% endtrans %}
{% endblock %}

{% block body %}

	{# Tableau contenant les images utilisées dans le carousel d'accueil #}
	{% set slides = [
    {
        image: 'images/slide1.avif',
       
    },
    {
        image: 'images/slide2.avif',
        
    },
    {
        image: 'images/slide3.avif',
        
    },
    {
        image: 'images/slide4.avif',
        
    },
    {
        image: 'images/slide5.avif',
        
    },
    {
        image: 'images/slide6.avif',
        
    }
] %}

	<!-- HERO CAROUSEL SECTION -->
	<section
		class="hero-carousel position-relative">

		{# Texte de bienvenue centré sur le carousel #}
		<div class="position-absolute top-50 start-50 translate-middle text-center text-white z-3 px-3 w-100">

			<h1 class="display-1 fw-bold hero-title mb-3" style="font-family: 'Playfair Display', serif; text-shadow: 2px 2px 4px rgba(0,0,0,0.7);">

				{% trans %}Bienvenue sur<br>{% endtrans %}

				<span class="text-success">
					<span class="s-letter">𝒮</span>araka
				</span>
			</h1>

			<p class="vision-text text-center text-light mx-auto mb-4" style="max-width: 600px; font-size: 1.25rem; text-shadow: 1px 1px 3px rgba(0,0,0,0.7);">
				{% trans %}La plateforme innovante de location et d'achat de produits. Économique, écologique et pratique.{% endtrans %}
			</p>

			<div class="d-flex flex-column align-items-center gap-2">
				<div class="d-flex justify-content-center gap-2 flex-wrap">
					<a href="{{ path('about') }}" class="btn btn-warning btn-lg text-dark rounded-pill px-3 shadow-slight">
						{% trans %}Découvrez la mission de
						<strong>
							<span>𝒮</span>araka</strong>
						{% endtrans %}
					</a>
					{% if app.user %}
						<a href="{{ path('app_article_new') }}" class="btn btn-success btn-lg text-white rounded-pill px-3 shadow-slight">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% else %}
						<a href="{{ path('app_register', {from: 'publish'}) }}" class="btn btn-success btn-lg text-white rounded-pill px-5 shadow-slight">
							{% trans %}Publier une annonce{% endtrans %}
						</a>
					{% endif %}
					<div><a href="#latest-products"  class="btn btn-outline-light btn-lg rounded-pill px-3">
                <i class="fas fa-shopping-bag me-2"></i>
                {% trans %}Découvrir les annonces{% endtrans %}
            </a></div>
			</div>

				</div>

				

		</div>

		<!-- Overlay -->
		<div class="position-absolute top-0 start-0 w-100 h-100" style="background: rgba(0,0,0,0.90);z-index:1;"></div>

		<!-- CAROUSEL -->
		<div id="carouselPromo" class="carousel slide carousel-fade" data-bs-ride="carousel">
			<div class="carousel-inner">
				{% for slide in slides %}
					<div class="carousel-item {% if loop.first %}active{% endif %}">
						<img src="{{ slide.image }}" class="d-block w-100" alt="{% trans %}Slide{% endtrans %} {{ loop.index }}">
					</div>
				{% endfor %}
			</div>
		</div>

		<!-- BOUTON PREVIOUS -->
		<button class="carousel-control-prev" type="button" data-bs-target="#carouselPromo" data-bs-slide="prev">
			<span class="carousel-control-prev-icon" aria-hidden="true"></span>
			<span class="visually-hidden">{% trans %}Précédent{% endtrans %}</span>
		</button>

		<!-- BOUTON NEXT -->
		<button class="carousel-control-next" type="button" data-bs-target="#carouselPromo" data-bs-slide="next">
			<span class="carousel-control-next-icon" aria-hidden="true"></span>
			<span class="visually-hidden">{% trans %}Suivant{% endtrans %}</span>
		</button>
	</section>


	<!-- PRODUCTS SECTION -->
	{# Section qui affiche les produits récents récupérés depuis la base de données #}

	<section id="latest-products" class="products py-3">
		<div class="container">
			<div class="row">
				{# Boucle qui parcourt les articles envoyés par le contrôleur #}
				{% for article in articles %}

					<div class="col-12 col-sm-6 col-lg-3 mb-4 d-flex">
						<div class="card product-card shadow-sm h-100 d-flex flex-column">

							{# {% if article.images|length > 0 %}

								{% for image in article.images|slice(0, 1) %} #}

									<img src="{{ asset('images/' ~ article.image) }}" class="card-img-top w-100" alt="{{ article.title }}" style="height: 200px; object-fit: cover;">

								{# {% endfor %}

							{% endif %} #}


							{# Contenu de alt-la carte avec résumé et type de transaction #}
							<div class="card-body">
								<h6 class="card-title">{{ article.title }}</h6>

								<p class="card-text small text-muted">
									{{ article.content|slice(0, 60) }}...
								</p>

								{% set type = article.transactionType|lower %}

								{# Choix de la classe de couleur selon le type #}
								{% if type == 'acheter' %}
									{% set badgeClass = 'bg-danger' %}
								{% elseif type == 'louer' %}
									{% set badgeClass = 'bg-primary' %}
								{% elseif type == 'brocante' %}
									{% set badgeClass = 'bg-orange' %}
									{# classe personnalisée pour brocante #}
								{% elseif type == 'don' %}
									{% set badgeClass = 'bg-success' %}
								{% elseif type == 'alimentaire' %}
									{% set badgeClass = 'bg-dark' %}
								{% else %}

									{% set badgeClass = 'bg-success' %}
									{# valeur par défaut #}
								{% endif %}

								<span class="badge rounded-pill px-3 py-2 {{ badgeClass }}">
									{{ article.transactionType|upper }}
								</span>
							</div>

							<div class="card-footer bg-white border-0">

								{% if article.slug %}
									<a href="{{ path('app_article_show', {'slug': article.slug}) }}" class="btn btn-success w-100">
										{% trans %}Voir le produit{% endtrans %}
									</a>
								{% else %}
									<button class="btn btn-secondary w-100" disabled>
										Indisponible
									</button>
								{% endif %}

								{% if app.user %}
									<a href="{{ path('app_conversation_start', {'articleId': article.id}) }}" class="btn btn-outline-success w-100 mt-2">
										{% trans %}Contacter le vendeur{% endtrans %}
									</a>
								{% else %}
									<a href="{{ path('app_register', { from: 'contact', articleId: article.id }) }}" class="btn btn-outline-success w-100 mt-2">
										{% trans %}Contacter le vendeur{% endtrans %}
									</a>
								{% endif %}

							</div>

						</div>

					</div>

				{% else %}

					{# Message affiché si aucun article n'est disponible #}
					<div class="col-12">
						<div class="alert alert-warning text-center">
							{% trans %}Aucun article disponible{% endtrans %}
						</div>
					</div>

				{% endfor %}

				{# Pagination permettant de naviguer entre les pages d'articles #}
				<div class="d-flex justify-content-center mt-4">
					{{ knp_pagination_render(articles) }}
				</div>

			</div>
		</div>
	</section>

	<!-- WHY 𝒮araka SECTION -->
<section id="why-saraka" class="advantages-section py-5">
    <div class="container">

        <div class="text-center mb-5">
            <span class="section-label">
                {% trans %}Pourquoi 𝒮araka ?{% endtrans %}
            </span>
            <h2 class="fw-bold mt-3">
                {% trans %}Pourquoi choisir 𝒮araka ?{% endtrans %}
            </h2>
            <p class="text-muted mt-2">
                {% trans %}Une plateforme qui révolutionne la consommation responsable et solidaire{% endtrans %}
            </p>
        </div>

        <div class="row g-4">

            <!-- Argument 1 : Prix avantageux -->
            <div class="col-md-6 col-lg-3">
                <div class="card advantage-card border-0 h-100">
                    <div class="card-body text-center">
                        <div class="advantage-circle">
                            <i class="fas fa-tags"></i>
                        </div>
                        <h3 class="advantage-title">
                            {% trans %}Des prix avantageux{% endtrans %}
                        </h3>
                        <p class="text-muted mb-0">
                            {% trans %}
                            Achetez ou louez à des prix bien plus bas que le marché traditionnel. 
                            Faites des affaires tout en soutenant l'économie circulaire.
                            {% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <!-- Argument 2 : Écologique -->
            <div class="col-md-6 col-lg-3">
                <div class="card advantage-card border-0 h-100">
                    <div class="card-body text-center">
                        <div class="advantage-circle">
                            <i class="fas fa-recycle"></i>
                        </div>
                        <h3 class="advantage-title">
                            {% trans %}Un geste écologique{% endtrans %}
                        </h3>
                        <p class="text-muted mb-0">
                            {% trans %}
                            Donnez une seconde vie aux produits et réduisez le gaspillage. 
                            Chaque échange est un pas vers un avenir plus durable.
                            {% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <!-- Argument 3 : Simple et rapide -->
            <div class="col-md-6 col-lg-3">
                <div class="card advantage-card border-0 h-100">
                    <div class="card-body text-center">
                        <div class="advantage-circle">
                            <i class="fas fa-bolt"></i>
                        </div>
                        <h3 class="advantage-title">
                            {% trans %}Simple et rapide{% endtrans %}
                        </h3>
                        <p class="text-muted mb-0">
                            {% trans %}
                            Trouvez ce dont vous avez besoin en quelques clics seulement. 
                            Une interface intuitive pour une expérience fluide.
                            {% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

            <!-- Argument 4 : Communauté -->
            <div class="col-md-6 col-lg-3">
                <div class="card advantage-card border-0 h-100">
                    <div class="card-body text-center">
                        <div class="advantage-circle">
                            <i class="fas fa-users"></i>
                        </div>
                        <h3 class="advantage-title">
                            {% trans %}Une communauté solidaire{% endtrans %}
                        </h3>
                        <p class="text-muted mb-0">
                            {% trans %}
                            Rejoignez une communauté de personnes partageant les mêmes valeurs 
                            de confiance, de partage et de solidarité.
                            {% endtrans %}
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

	{% endblock %}
