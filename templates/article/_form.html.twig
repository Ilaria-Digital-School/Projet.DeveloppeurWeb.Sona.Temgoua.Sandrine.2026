{{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

{{ form_errors(form) }}

<div class="row g-3">

    <div class="col-12">
        {{ form_row(form.title) }}
    </div>

    <div class="col-12">
        {{ form_row(form.summary) }}
    </div>

    <div class="col-12">
        {{ form_row(form.content) }}
    </div>

    {#  AJOUT OBLIGATOIRE #}
    <div class="col-md-6">
        {{ form_row(form.cathegory) }}
    </div>

    <div class="col-md-6">
        {{ form_row(form.transactionType) }}
    </div>

    {# Image principale #}
    <div class="col-12">
        {{ form_row(form.image) }}
    </div>

    {# Upload images #}
<div class="col-12 mt-3">

    <label class="form-label fw-semibold">📸 Ajouter des images</label>

    <div id="dropzone"
         class="border border-2 border-dashed rounded-4 p-5 text-center bg-light position-relative">

        <div class="mb-2 fs-4">📸</div>
        <p class="fw-semibold mb-1">Glissez vos images ici</p>
        <p class="text-muted small mb-0">ou cliquez pour sélectionner</p>

        {{ form_widget(form.images, {
            'attr': {
                'multiple': true,
                'id': 'fileInput',
                'class': 'position-absolute top-0 start-0 w-100 h-100 opacity-0'
            }
        }) }}


        <div id="previewContainer" class="row mt-3 g-3"></div>

    </div>

    <div id="preview" class="row mt-4 g-3"></div>

</div>

{{ form_rest(form) }}

<div class="d-flex justify-content-end mt-4">
    <button class="btn btn-success rounded-pill px-4">
        {{ button_label|default('Enregistrer') }}
    </button>
</div>


<script>
document.addEventListener('DOMContentLoaded', function () {

    const fileInput = document.getElementById('fileInput');
    const previewContainer = document.getElementById('previewContainer');

    fileInput.addEventListener('change', function () {

        previewContainer.innerHTML = '';

        const files = this.files;

        for (let i = 0; i < files.length; i++) {

            const file = files[i];

            if (!file.type.startsWith('image/')) {
                continue;
            }

            const reader = new FileReader();

            reader.onload = function (e) {

                const col = document.createElement('div');
                col.className = 'col-6 col-md-3';

                col.innerHTML = `
                    <div class="card shadow-sm border-0">
                        <img src="${e.target.result}" 
                             class="card-img-top rounded"
                             style="height: 180px; object-fit: cover;">
                    </div>
                `;

                previewContainer.appendChild(col);
            };

            reader.readAsDataURL(file);
        }

    });

});
</script>

{{ form_end(form) }}

