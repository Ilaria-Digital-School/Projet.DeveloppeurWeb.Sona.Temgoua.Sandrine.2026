{% for article in articles %}

<tr>
    <td>
        <div class="d-flex align-items-center">

            {% set total = article.images|length %}

{% if total > 0 %}
    
    {% for image in article.images|slice(0, 5) %}
        <img src="{{ asset('images/' ~ image.image) }}"
             class="rounded me-2"
             style="width:40px; height:40px; object-fit:cover;">
    {% endfor %}

    {% if total > 5 %}
        <span class="ms-2">+{{ total - 5 }}</span>
    {% endif %}

{% else %}
    <div class="bg-light d-flex align-items-center justify-content-center rounded me-3"
         style="width:40px; height:40px;">
        N/A
    </div>
{% endif %}

                </div>

                <small class="text-muted">ID: {{ article.id }}</small>
            </div>

        </div>
    </td>

    <td>
        <span class="badge bg-secondary">
            {{ article.cathegory ? article.cathegory.name : 'Non catégorisé' }}
        </span>
    </td>

    <td>
        <span class="text-muted small">
            {{ article.images|length }} image(s)
        </span>
    </td>

    <td>
        {% if article.isVerified %}
            <span class="badge bg-success">
                <i class="bi bi-check-circle me-1"></i>Publié
            </span>
        {% else %}
            <span class="badge bg-warning text-dark">
                <i class="bi bi-clock me-1"></i>Brouillon
            </span>
        {% endif %}
    </td>

    <td class="text-muted small">
        {{ article.publishedAt ? article.publishedAt|date('d/m/Y H:i') : 'Non publié' }}
    </td>

    <td>
        <div class="d-flex gap-2">

            {% if article.slug %}
                <a href="{{ path('app_article_show', {'slug': article.slug}) }}"
                   class="text-primary">
                    <i class="bi bi-eye"></i>
                </a>
            {% else %}
                <span class="text-muted">
                    <i class="bi bi-eye"></i>
                </span>
            {% endif %}

            {% if not article.isDeleted %}
                <a href="{{ path('app_article_edit', {'id': article.id}) }}"
                   class="text-success">
                    <i class="bi bi-pencil"></i>
                </a>
            {% else %}
                <span class="text-muted">
                    <i class="bi bi-pencil"></i>
                </span>
            {% endif %}

            <button type="button"
                    class="delete-btn text-danger"
                    data-id="{{ article.id }}"
                    data-token="{{ csrf_token('delete' ~ article.id) }}">
                <i class="bi bi-trash"></i>
            </button>

        </div>
    </td>

</tr>

{% else %}

<tr>
    <td colspan="6" class="text-center py-5 text-muted">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        Aucun article trouvé
    </td>
</tr>

{% endfor %}