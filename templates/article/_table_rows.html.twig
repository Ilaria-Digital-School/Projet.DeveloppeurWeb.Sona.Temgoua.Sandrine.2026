{# templates/article/_table_rows.html.twig #}

{% for article in articles %}
    <tr class="hover:bg-gray-50">
        <td class="px-6 py-4">
            <div class="flex items-center">
                {% if article.image %}
                    <img class="h-10 w-10 rounded object-cover" src="{{ asset('images/' ~ article.image) }}" alt="{{ article.title }}">
                {% else %}
                    <div class="h-10 w-10 rounded bg-gray-200 flex items-center justify-center">
                        <i class="fas fa-image text-gray-400"></i>
                    </div>
                {% endif %}
                <div class="ml-3">
                    <div class="text-sm font-medium text-gray-900">{{ article.title|slice(0, 50) }}{% if article.title|length > 50 %}...{% endif %}</div>
                    <div class="text-xs text-gray-500">ID: {{ article.id }}</div>
                </div>
            </div>
        </td>
        <td class="px-6 py-4">
            <span class="px-2 py-1 text-xs rounded-full bg-purple-100 text-purple-800">
                {{ article.cathegory ? article.cathegory.name : 'Non catégorisé' }}
            </span>
        </td>
        <td class="px-6 py-4">
            <span class="text-sm text-gray-600">{{ article.images|length }} image(s)</span>
        </td>
        <td class="px-6 py-4">
            {% if article.isVerified %}
                <span class="px-2 py-1 text-xs rounded-full bg-green-100 text-green-800">
                    <i class="fas fa-check-circle mr-1"></i>Publié
                </span>
            {% else %}
                <span class="px-2 py-1 text-xs rounded-full bg-orange-100 text-orange-800">
                    <i class="fas fa-clock mr-1"></i>Brouillon
                </span>
            {% endif %}
        </td>
        <td class="px-6 py-4 text-sm text-gray-500">
            {{ article.publishedAt ? article.publishedAt|date('d/m/Y H:i') : 'Non publié' }}
        </td>
        <td class="px-6 py-4">
            <div class="flex space-x-2">
                <a href="{{ path('app_article_show', {'slug': article.slug}) }}" class="text-blue-600 hover:text-blue-800" title="Voir">
                    <i class="fas fa-eye"></i>
                </a>
                <a href="{{ path('app_article_edit', {'id': article.id}) }}" class="text-green-600 hover:text-green-800" title="Modifier">
                    <i class="fas fa-edit"></i>
                </a>
                <button type="button" 
                        class="delete-btn text-red-600 hover:text-red-800" 
                        data-id="{{ article.id }}"
                        data-token="{{ csrf_token('delete' ~ article.id) }}"
                        title="Supprimer">
                    <i class="fas fa-trash"></i>
                </button>
            </div>
        </td>
    </tr>
{% else %}
    <tr>
        <td colspan="6" class="px-6 py-12 text-center text-gray-500">
            <i class="fas fa-inbox text-4xl mb-2 block"></i>
            <p>Aucun article trouvé</p>
        </td>
    </tr>
{% endfor %}