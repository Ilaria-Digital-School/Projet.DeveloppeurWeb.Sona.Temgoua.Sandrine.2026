{% extends 'base.html.twig' %}

{% block title %}{% trans %}Gestion des articles{% endtrans %}{% endblock %}

{% block body %}
<div class="container py-5">

    {# FLASH #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success shadow-sm">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger shadow-sm">
            {{ message }}
        </div>
    {% endfor %}

    <h1 class="fw-bold text-success mb-4">{% trans %}Articles{% endtrans %}</h1>

    {# SEARCH + BUTTON #}
    <div class="row g-3 align-items-center mb-4">
        <div class="col-md">
            <div class="input-group">
                <span class="input-group-text bg-white">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" id="searchInput"
                       class="form-control"
                       placeholder="{% trans %}Rechercher un article...{% endtrans %}">
            </div>
        </div>

        <div class="col-md-auto">
            <a href="{{ path('app_article_new') }}"
               class="btn btn-success rounded-pill px-4">
                <i class="bi bi-plus-lg me-2"></i>
                {% trans %}Nouvel annonce{% endtrans %}
            </a>
        </div>
    </div>

    {# SPINNER #}
    <div id="searchSpinner" class="text-center my-4 d-none">
        <div class="spinner-border text-success"></div>
    </div>

    {# TABLE #}
    <div class="table-responsive bg-white rounded-4 shadow-sm">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Article</th>
                    <th>Catégorie</th>
                    <th>Images</th>
                    <th>Statut</th>
                    <th>Publié le</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody id="articlesTableBody">
                {% include 'article/_table_rows.html.twig' with {articles: articles} %}
            </tbody>
        </table>
    </div>

    {# PAGINATION #}
    <div class="mt-4">
        {{ knp_pagination_render(articles) }}
    </div>

</div>
{% endblock %}