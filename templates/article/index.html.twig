{% extends 'base.html.twig' %}

{% block title %}{% trans %}Articles{% endtrans %}
{% endblock %}

{% block body %}

<div class="container my-5">

	<h1 class="mb-4 text-success fw-bold">{% trans %}Articles{% endtrans %}</h1>

	<div class="table-responsive">
		<table class="table table-striped table-hover align-middle shadow-sm border rounded">
			<thead class="table-success">
				<tr>
					<th>N°</th>
					<th>{% trans %}Title{% endtrans %}</th>
					<th>{% trans %}Résumé{% endtrans %}</th>
                    <th>{% trans %}Contenu{% endtrans %}</th>
                    <th>{% trans %}Image{% endtrans %}</th>
					<th>{% trans %}Date publication{% endtrans %}</th>
					<th>{% trans %}Vérifié{% endtrans %}</th>
					<th>{% trans %}Actions{% endtrans %}</th>
				</tr>
			</thead>
			<tbody>
				{% for article in articles %}
					<tr>
						<td class="fw-semibold">{{ article.id }}</td>

						<td class="fw-semibold text-success">
							{{ article.title }}
						</td>

						<td style="max-width:200px;" class="text-truncate">
							{{ article.summary }}
						</td>

						<td style="max-width:250px;" class="text-truncate">
							{{ article.content }}
						</td>

						<td>
							{% if article.image %}
								<img src="{{ asset('images/' ~ article.image) }}"
								     alt="{{ article.title }}"
								     width="100"
								     class="img-fluid rounded shadow-sm">
							{% else %}
								<span class="text-muted fst-italic">No image</span>
							{% endif %}
						</td>

						<td class="text-muted small">
							{{ article.publishedAt ? article.publishedAt|date('Y-m-d H:i:s') : '' }}
						</td>

						<td>
							{% if article.isVerified %}
								<span class="badge bg-success">{% trans %}Oui{% endtrans %}</span>
							{% else %}
								<span class="badge bg-secondary">{% trans %}Non{% endtrans %}</span>
							{% endif %}
						</td>

						{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_AUTHOR') %}
						<td>
							<a href="{{ path('app_article_show', {'id': article.id}) }}"
							   class="btn btn-sm btn-outline-success me-2">
								{% trans %}Afficher{% endtrans %}
							</a>

							<a href="{{ path('app_article_edit', {'id': article.id}) }}"
							   class="btn btn-sm btn-success">
								{% trans %}Editer{% endtrans %}
							</a>
							{{ include('article/_delete_form.html.twig') }}
						</td>
						{% endif %}
					</tr>
				{% else %}
					<tr>
						<td colspan="8" class="text-center text-muted py-4">
							{% trans %}Pas d'enregistrements{% endtrans %}
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>

	<a href="{{ path('app_article_new') }}" class="btn btn-success mt-3">
		Create new
	</a>

</div>

{% endblock %}
