{# templates/article/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Gestion des articles - Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">
    <div class="container mx-auto px-4 py-8">
    
        {# Messages flash #}
        {% for message in app.flashes('success') %}
            <div class="mb-4 p-4 bg-green-100 border-l-4 border-green-500 text-green-700 rounded shadow">
                {{ message }}
            </div>
        {% endfor %}
        
        {% for message in app.flashes('error') %}
            <div class="mb-4 p-4 bg-red-100 border-l-4 border-red-500 text-red-700 rounded shadow">
                {{ message }}
            </div>
        {% endfor %}
        
        <!-- Header Premium -->
        <div class="mb-8 flex justify-between items-center flex-wrap gap-4">
            <div>
                <h1 class="text-4xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                    Gestion des Articles
                </h1>
                <p class="text-gray-600 mt-2">Gérez votre contenu comme un pro</p>
            </div>
            <div class="flex gap-4">
                <!-- Barre de recherche dynamique -->
                <div class="relative">
                    <input type="text" 
                           id="searchInput" 
                           placeholder="Rechercher un article..." 
                           class="pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent w-64"
                           value="{{ search|default('') }}">
                    <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
                    <div id="searchSpinner" class="absolute right-3 top-2 hidden">
                        <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-blue-500"></div>
                    </div>
                </div>
                
                <a href="{{ path('app_article_new') }}" class="group relative inline-flex items-center px-6 py-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200">
                    <i class="fas fa-plus mr-2 group-hover:rotate-90 transition-transform duration-200"></i>
                    Nouvel Article
                </a>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm">Total Articles</p>
                        <p class="text-3xl font-bold text-gray-800" id="totalStats">{{ stats.total }}</p>
                    </div>
                    <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-newspaper text-blue-600 text-xl"></i>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm">Publiés</p>
                        <p class="text-3xl font-bold text-green-600" id="publishedStats">{{ stats.published }}</p>
                    </div>
                    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-check-circle text-green-600 text-xl"></i>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-500 text-sm">Brouillons</p>
                        <p class="text-3xl font-bold text-orange-600" id="draftsStats">{{ stats.drafts }}</p>
                    </div>
                    <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-pencil-alt text-orange-600 text-xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Articles Table Premium -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gradient-to-r from-gray-50 to-gray-100">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Article</th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Catégorie</th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Images</th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Statut</th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Publié le</th>
                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="articlesTableBody" class="bg-white divide-y divide-gray-200">
                        {% include 'article/_table_rows.html.twig' with {articles: articles} %}
                    </tbody>
                </table>
            </div>
            
            <!-- Pagination -->
            <div id="paginationContainer" class="px-6 py-4 bg-gray-50 border-t border-gray-200">
                {% include 'article/_pagination.html.twig' with {
                    currentPage: currentPage,
                    totalPages: totalPages,
                    search: search
                } %}
            </div>
        </div>
    </div>
</div>

<style>
    @keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }
    
    .animate-spin {
        animation: spin 1s linear infinite;
    }
    
    .transition-all {
        transition-property: all;
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
        transition-duration: 150ms;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    let searchTimeout;

    const searchInput = document.getElementById('searchInput');
    const spinner = document.getElementById('searchSpinner');
    const tableBody = document.getElementById('articlesTableBody');
    const paginationContainer = document.getElementById('paginationContainer');

    /**
     * 🔥 Fonction principale (RECHERCHE + PAGINATION)
     */
    async function loadArticles(page = 1) {
        const search = searchInput ? searchInput.value : '';

        try {
            spinner?.classList.remove('hidden');

            const response = await fetch(
                `/article/search-articles?search=${encodeURIComponent(search)}&page=${page}`,
                {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                }
            );

            const data = await response.json();

            // 🔥 MAJ DOM
            tableBody.innerHTML = data.html;
            paginationContainer.innerHTML = data.paginationHtml;

            // 🔥 Réattacher events
            attachPaginationEvents();
            initDeleteButtons();

            // 🔥 Update URL (pro)
            updateUrl(search, page);

        } catch (error) {
            console.error(error);
            showNotification('Erreur de chargement', 'error');
        } finally {
            spinner?.classList.add('hidden');
        }
    }

    /**
     * 🔍 RECHERCHE (debounce)
     */
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => loadArticles(1), 400);
        });
    }

    /**
     * 📄 PAGINATION
     */
    function attachPaginationEvents() {
        document.querySelectorAll('.pagination-link').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const page = this.dataset.page;
                loadArticles(page);
            });
        });
    }

    /**
     * 🗑 DELETE
     */
    function initDeleteButtons() {
        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                const id = this.dataset.id;
                const token = this.dataset.token;

                if (!confirm('Supprimer cet article ?')) return;

                try {
                    const res = await fetch(`/article/${id}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded'
                        },
                        body: new URLSearchParams({ _token: token })
                    });

                    if (res.ok) {
                        this.closest('tr').remove();
                        showNotification('Supprimé ✔');
                        updateStats();

                        // reload si table vide
                        if (!document.querySelector('#articlesTableBody tr')) {
                            loadArticles();
                        }
                    }

                } catch (err) {
                    console.error(err);
                }
            });
        });
    }

    /**
     * 🔗 URL propre
     */
    function updateUrl(search, page) {
        const url = new URL(window.location);

        if (search) {
            url.searchParams.set('search', search);
        } else {
            url.searchParams.delete('search');
        }

        url.searchParams.set('page', page);
        window.history.pushState({}, '', url);
    }

    /**
     * 🔔 NOTIF
     */
    function showNotification(message, type = 'success') {
        const div = document.createElement('div');
        div.className = `fixed top-4 right-4 px-4 py-2 rounded text-white ${
            type === 'success' ? 'bg-green-500' : 'bg-red-500'
        }`;
        div.textContent = message;

        document.body.appendChild(div);

        setTimeout(() => div.remove(), 3000);
    }

    /**
     * 📊 STATS
     */
    function updateStats() {
        fetch('/article/stats')
            .then(r => r.json())
            .then(data => {
                document.getElementById('totalStats').textContent = data.total;
                document.getElementById('publishedStats').textContent = data.published;
                document.getElementById('draftsStats').textContent = data.drafts;
            });
    }

    // 🔥 INIT
    attachPaginationEvents();
    initDeleteButtons();
});
</script>
{% endblock %}