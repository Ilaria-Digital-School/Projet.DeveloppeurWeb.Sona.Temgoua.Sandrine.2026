{% extends 'base.html.twig' %}

{% block title %}{{ article.title }}{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-lg-10">

           {# CARD PRINCIPALE #}

<div class="card border-0 shadow-lg rounded-4 overflow-hidden">

    {# SLIDER IMAGES #}

    {% if article.images|length > 0 %}
    <div id="articleCarousel"
         class="carousel slide"
         data-bs-ride="carousel"
         role="region"
         aria-label="Galerie d'images de l'annonce">

        <div class="carousel-inner">

            {% for image in article.images %}
            <div class="carousel-item {% if loop.first %}active{% endif %}">

                <div class="position-relative">

                    <img
                        src="{{ asset('images/' ~ image.image) }}"
                        class="d-block w-100"
                        style="height: 400px; object-fit: cover;"

                        {# ACCESSIBILITÉ :
                           Le lecteur d'écran annoncera le titre
                           de l'annonce associé à l'image. #}
                        alt="Photo de l'annonce : {{ article.title }}"
                    >

                    {# BOUTON SUPPRIMER SUR IMAGE (OWNER ONLY) #}

                    {% if is_granted('ARTICLE_DELETE', article) %}
                        <form method="post"
                              action="{{ path('app_image_delete', {'id': image.id}) }}"
                              class="position-absolute top-0 end-0 m-3">

                            <input type="hidden"
                                   name="_token"
                                   value="{{ csrf_token('delete' ~ image.id) }}">

                            <button
                                class="btn btn-danger btn-sm shadow"

                                {# ACCESSIBILITÉ :
                                   Le lecteur d'écran comprend
                                   précisément l'action du bouton. #}
                                aria-label="Supprimer cette image de l'annonce"
                            >
                                🗑 Supprimer
                            </button>

                        </form>
                    {% endif %}

                </div>

            </div>
            {% endfor %}

                    </div>

                    {# CONTROLS #}
                    <button class="carousel-control-prev" type="button" data-bs-target="#articleCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>

                    <button class="carousel-control-next" type="button" data-bs-target="#articleCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>

                </div>
                {% endif %}

            
                {# CONTENU ARTICLE      #}
                
                <div class="card-body p-5">

                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h1 class="fw-bold">{{ article.title }}</h1>

                        {% if article.isVerified %}
                            <span class="badge bg-success">✔ Verified</span>
                        {% endif %}
                    </div>

                    <p class="text-muted mb-4">
                        {{ article.publishedAt ? article.publishedAt|date('d M Y à H:i') : '' }}
                    </p>

                    <h5 class="fw-semibold">Résumé</h5>
                    <p class="text-muted">{{ article.summary }}</p>

                    <hr>

                    <h5 class="fw-semibold">Contenu</h5>
                    <p style="line-height: 1.8;">
                        {{ article.content }}
                    </p>

                </div>

            </div>

        
            {# ACTIONS #}
            
            <div class="d-flex justify-content-between mt-4">

                {% if app.user %}
                    <a href="{{ path('app_my_articles') }}" class="btn btn-outline-success rounded-pill px-4">
                        ← Retour
                    </a>
                {% else %}
                    <a href="{{ path('app_home') }}" class="btn btn-outline-success rounded-pill px-4">
                        ← Accueil
                    </a>
                {% endif %}

                {% if app.user %}
                <div class="d-flex gap-2">

                    {% if is_granted('ARTICLE_EDIT', article) %}
                        <a href="{{ path('app_article_edit', {'id': article.id}) }}"
                           class="btn btn-success rounded-pill px-4">
                            ✏ Modifier
                        </a>
                    {% endif %}

                    {% if is_granted('ARTICLE_DELETE', article) %}
                        {{ include('article/_delete_form.html.twig') }}
                    {% endif %}

                </div>
                {% endif %}

            </div>

        </div>
    </div>

</div>
{% endblock %}