{% extends 'base.html.twig' %}

{% block title %}Créer un article{% endblock %}

{% block body %}
<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-lg-10">

            {# CARD PRINCIPALE (comme show) #}
            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body p-5">

                    {# HEADER aligné avec ton style #}
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1 class="fw-bold mb-0">📝 Nouvel article</h1>

                        <a href="{{ path('app_article_index') }}"
                           class="btn btn-outline-secondary rounded-pill px-4">
                            ← Retour
                        </a>
                    </div>

                    {# FORM #}
                    {{ include('article/_form.html.twig', {
                        form: form,
                        button_label: 'Publier'
                    }) }}

                </div>

            </div>

        </div>
    </div>

</div>
{% endblock %}