{% extends 'base.html.twig' %}

{% block body %}

	<div class="conv-container">

		<h2>💬 Mes conversations</h2>

		{% for conversation in conversations %}

    {% if is_granted('ROLE_ADMIN')
        or conversation.buyer == app.user
        or conversation.seller == app.user %}

        {% set otherUser = conversation.buyer == app.user 
            ? conversation.seller 
            : conversation.buyer %}

        {% set lastMessage = conversation.messages|last %}

        <a href="{{ path('app_conversation_show', {id: conversation.id}) }}" class="conv-item">

            <div>
                <div class="conv-title">
                    {{ otherUser.email }}
                </div>

                <div class="conv-last">
                    {{ lastMessage ? lastMessage.content|slice(0,40) : 'Aucun message' }}
                </div>
            </div>

            {% if lastMessage 
                and lastMessage.sender != app.user 
                and not lastMessage.readAt %}

                <span style="color:green;">●</span>

            {% endif %}

        </a>

    {% endif %}

{% else %}

    <p>Aucune conversation</p>

{% endfor %}