{% extends 'base.html.twig' %}

{% block title %}Conversation
{% endblock %}

{% block body %}

	<link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

	<div class="container py-4">
		<div
			class="chat-container d-flex flex-column">

			<!-- HEADER -->
			<div class="chat-header d-flex justify-content-between align-items-center">
				<span class="fw-semibold">
					💬
					{{ otherUser.firstname ?? ''}}
					{{ otherUser.lastname ?? '' }}
				</span>

				<div class="d-flex gap-2">
					<button class="icon-btn call" onclick="startCall()">
						<i class="ri-phone-line"></i>
					</button>
					<button class="icon-btn video" onclick="startVideoCall()">
						<i class="ri-vidicon-line"></i>
					</button>
				</div>
			</div>

			<!-- MESSAGES -->
			<div class="chat-messages" id="chat">

				{% for message in conversation.messages %}
					<div class="message-wrapper d-flex flex-column {% if message.sender == app.user %}align-items-end{% else %}align-items-start{% endif %}">

						{% if message.replyTo %}
							<div class="reply-box">
								{{ message.replyTo.content|slice(0, 50) }}
							</div>
						{% endif %}

						<div class="message-bubble {% if message.sender == app.user %}me{% else %}other{% endif %}">
							{{ message.content }}

							{% if message.imagePath %}
								<img src="{{ asset(message.imagePath) }}" class="img-fluid mt-2">
							{% endif %}

							{% if message.filePath %}
								<div>
									<a href="{{ asset(message.filePath) }}">📎 Télécharger</a>
								</div>
							{% endif %}

							{% if message.audioPath %}
								<audio controls class="mt-2 w-100">
									<source src="{{ asset(message.audioPath) }}">
								</audio>
							{% endif %}
						</div>

						{% if message.sender == app.user %}
							<small class="text-muted mt-1 d-block text-end">
								{% if message.readAt %}
									✔✔ Lu
								{% else %}
									✔ Envoyé
								{% endif %}
								{{ message.createdAt|date('d/m H:i') }}
							</small>
						{% else %}
							<small class="text-muted mt-1 d-block">
								{{ message.createdAt|date('d/m H:i') }}
							</small>
						{% endif %}

						<div class="message-actions">
							<button class="icon-btn" onclick="replyTo({{ message.id }}, '{{ message.content|e('js') }}')">
								<i class="ri-reply-line"></i>
							</button>
						</div>

					</div>
				{% endfor %}

			</div>

			<!-- INPUT -->

			<form
				method="post" action="{{ path('app_message_send', {id: conversation.id}) }}" enctype="multipart/form-data" class="chat-input d-flex align-items-center gap-2">

				{# 📷 Image #}
				<label for="imageInput" class="icon-btn" title="Joindre une image">
					<i class="ri-image-line"></i>
				</label>
				<input
				type="file" name="image" accept="image/*" class="d-none" id="imageInput">

				{# 📎 Fichier #}
				<label for="fileInput" class="icon-btn" title="Joindre un fichier">
					<i class="ri-attachment-2"></i>
				</label>
				<input
				type="file" name="file" class="d-none" id="fileInput">

				{# 🎵 AUDIO #}
				<label for="audioInput" class="icon-btn" title="Joindre un audio">
					<i class="ri-mic-line"></i>
				</label>
				<input
				type="file" name="audio" accept="audio/*" class="d-none" id="audioInput">

				{# 💬 Message #}
				<input
				type="text" name="content" id="messageInput" class="form-control rounded-pill" placeholder="Message..." autocomplete="off">

				{# 🔁 Reply #}
				<input
				type="hidden" name="replyTo" id="replyTo">

				{# 🚀 Send #}
				<button type="submit" class="send-btn">
					<i class="ri-send-plane-fill"></i>
				</button>
			</form>

		</div>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/emoji-picker-element"></script>
	<emoji-picker id="emojiPicker" style="display:none;"></emoji-picker>

	<script>
		const chat = document.getElementById('chat');
chat.scrollTop = chat.scrollHeight;
	</script>

{% endblock %}
