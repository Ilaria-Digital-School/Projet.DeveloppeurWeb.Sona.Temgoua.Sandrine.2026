{# templates/admin/articles/edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Modifier l'article (admin){% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Modifier l'article n°{{ article.id }} : {{ article.title }}</h1>

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        {{ form_errors(form) }}

        <div class="row">
            <div class="col-md-8">
                {{ form_row(form.title) }}
                {{ form_row(form.summary) }}
                {{ form_row(form.content) }}
                {{ form_row(form.price) }}
                {{ form_row(form.transactionType) }}
            </div>
            <div class="col-md-4">
                {{ form_row(form.images) }}

                {# Affichage des images existantes #}
                {% if article.images|length > 0 %}
                    <div class="mt-3">
                        <label class="form-label">Images actuelles</label>
                        <div class="row">
                            {% for image in article.images %}
                                <div class="col-6 mb-2">
                                    <img src="{{ asset('uploads/' ~ image.image) }}" class="img-thumbnail" style="max-height: 100px;">
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>

        <button type="submit" class="btn btn-success">Enregistrer les modifications</button>
        <a href="{{ path('app_admin_article_index') }}" class="btn btn-secondary">Annuler</a>

    {{ form_end(form) }}
</div>
{% endblock %}