{# templates/admin/articles/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Administration des articles{% endblock %}

{% block body %}
<div class="container mt-3 mt-md-4 px-2 px-md-3">
    <h1 class="fs-2 fs-md-1 mb-3 mb-md-4">Gestion des articles</h1>

    {# Affichage des messages flash #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Barre de recherche responsive #}
    <form method="get" class="mb-3 mb-md-4">
        <div class="d-flex flex-column flex-sm-row gap-2">
            <div class="flex-grow-1">
                <input type="text" name="search" class="form-control" placeholder="Rechercher par titre ou résumé..." value="{{ app.request.query.get('search') }}">
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary flex-grow-1 flex-sm-grow-0" type="submit">Rechercher</button>
                {% if app.request.query.get('search') %}
                    <a href="{{ path('app_admin_article_index') }}" class="btn btn-secondary flex-grow-1 flex-sm-grow-0">Réinitialiser</a>
                {% endif %}
            </div>
        </div>
    </form>

    {# Statistiques rapides - version responsive #}
    <div class="row g-2 g-md-3 mb-3 mb-md-4">
        <div class="col-4 col-md-4">
            <div class="card text-white bg-primary h-100">
                <div class="card-body p-2 p-md-3 text-center">
                    <h6 class="card-title mb-0 fs-6 fs-md-5">Total</h6>
                    <p class="card-text display-6 display-md-4 mb-0">{{ stats.total|default(0) }}</p>
                </div>
            </div>
        </div>
        <div class="col-4 col-md-4">
            <div class="card text-white bg-success h-100">
                <div class="card-body p-2 p-md-3 text-center">
                    <h6 class="card-title mb-0 fs-6 fs-md-5">Publiés</h6>
                    <p class="card-text display-6 display-md-4 mb-0">{{ stats.published|default(0) }}</p>
                </div>
            </div>
        </div>
        <div class="col-4 col-md-4">
            <div class="card text-white bg-warning h-100">
                <div class="card-body p-2 p-md-3 text-center">
                    <h6 class="card-title mb-0 fs-6 fs-md-5">Brouillons</h6>
                    <p class="card-text display-6 display-md-4 mb-0">{{ stats.drafts|default(0) }}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Version mobile : cartes -->
    <div class="d-md-none">
        {% for article in articles %}
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="card-title fw-bold mb-0 text-truncate" style="max-width: 70%;">
                            {{ article.title|slice(0, 40) }}{% if article.title|length > 40 %}...{% endif %}
                        </h6>
                        <span class="badge {% if article.isVerified %}bg-success{% else %}bg-danger{% endif %}">
                            {% if article.isVerified %}Validé{% else %}En attente{% endif %}
                        </span>
                    </div>
                    
                    <div class="d-flex flex-wrap gap-1 mb-2">
                        <span class="badge bg-secondary">#{{ article.id }}</span>
                        <span class="badge bg-light text-dark">{{ article.author.email }}</span>
                        {% set type = article.transactionType|lower %}
                        {% if type == 'acheter' %}
                            <span class="badge bg-danger">ACHETER</span>
                        {% elseif type == 'louer' %}
                            <span class="badge bg-primary">LOUER</span>
                        {% elseif type == 'brocante' %}
                            <span class="badge bg-warning text-dark">BROCANTE</span>
                        {% elseif type == 'don' %}
                            <span class="badge bg-success">DON</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ article.transactionType|upper }}</span>
                        {% endif %}
                    </div>
                    
                    <div class="small text-muted mb-2">
                        Publié : {{ article.publishedAt ? article.publishedAt|date('d/m/Y H:i') : '-' }}
                    </div>
                    
                    {% if article.images|length > 0 %}
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            {% for image in article.images|slice(0, 3) %}
                                <img src="{{ asset('images/' ~ image.image) }}" alt="miniature" style="width: 40px; height: 40px; object-fit: cover;" class="rounded border">
                            {% endfor %}
                            {% if article.images|length > 3 %}
                                <span class="badge bg-secondary">+{{ article.images|length - 3 }}</span>
                            {% endif %}
                        </div>
                    {% endif %}
                    
                    <div class="d-flex gap-1 flex-wrap">
                        <a href="{{ path('app_article_show', {slug: article.slug}) }}" class="btn btn-info btn-sm flex-grow-1" target="_blank">Voir</a>
                        <a href="{{ path('app_article_edit', {id: article.id}) }}" class="btn btn-warning btn-sm flex-grow-1">Modifier</a>
                        <form method="post" action="{{ path('app_article_delete', {id: article.id}) }}" class="flex-grow-1" onsubmit="return confirm('Supprimer définitivement cet article ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_delete_article_' ~ article.id) }}">
                            <button class="btn btn-danger btn-sm w-100">Supprimer</button>
                        </form>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="text-center text-muted py-4">
                <p class="mb-0">Aucun article trouvé.</p>
            </div>
        {% endfor %}
    </div>

    <!-- Version tablette et desktop : tableau -->
    <div class="d-none d-md-block table-responsive rounded shadow-sm">
        <table class="table table-bordered table-hover table-sm">
            <thead class="table-dark">
                <tr>
                    <th class="d-none d-lg-table-cell">ID</th>
                    <th>Titre</th>
                    <th class="d-none d-xl-table-cell">Auteur</th>
                    <th class="d-none d-lg-table-cell">Type</th>
                    <th class="d-none d-xl-table-cell">Images</th>
                    <th class="d-none d-lg-table-cell">Publié le</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for article in articles %}
                    <tr>
                        <td class="d-none d-lg-table-cell">{{ article.id }}</td>
                        <td>{{ article.title|slice(0, 30) }}{% if article.title|length > 30 %}...{% endif %}</td>
                        <td class="d-none d-xl-table-cell">{{ article.author.email|slice(0, 20) }}{% if article.author.email|length > 20 %}...{% endif %}</td>
                        <td class="d-none d-lg-table-cell">
                            {% set type = article.transactionType|lower %}
                            {% if type == 'acheter' %}
                                <span class="badge bg-danger">ACHETER</span>
                            {% elseif type == 'louer' %}
                                <span class="badge bg-primary">LOUER</span>
                            {% elseif type == 'brocante' %}
                                <span class="badge bg-warning text-dark">BROCANTE</span>
                            {% elseif type == 'don' %}
                                <span class="badge bg-success">DON</span>
                            {% else %}
                                <span class="badge bg-secondary">{{ article.transactionType|upper }}</span>
                            {% endif %}
                        </td>
                        <td class="d-none d-xl-table-cell">
                            {% if article.images|length > 0 %}
                                <div class="d-flex flex-wrap gap-1">
                                    {% for image in article.images|slice(0, 2) %}
                                        <img src="{{ asset('images/' ~ image.image) }}" alt="miniature" style="width: 40px; height: 40px; object-fit: cover;" class="rounded border">
                                    {% endfor %}
                                    {% if article.images|length > 2 %}
                                        <span class="badge bg-secondary">+{{ article.images|length - 2 }}</span>
                                    {% endif %}
                                </div>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="d-none d-lg-table-cell">{{ article.publishedAt ? article.publishedAt|date('d/m/Y H:i') : '-' }}</td>
                        <td>
                            {% if article.isVerified %}
                                <span class="badge bg-success">Validé</span>
                            {% else %}
                                <span class="badge bg-danger">En attente</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('app_article_show', {slug: article.slug}) }}" class="btn btn-info" target="_blank">Voir</a>
                                <a href="{{ path('app_article_edit', {id: article.id}) }}" class="btn btn-warning">Modifier</a>
                                <form method="post" action="{{ path('app_article_delete', {id: article.id}) }}" style="display:inline-block;" onsubmit="return confirm('Supprimer définitivement cet article ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_delete_article_' ~ article.id) }}">
                                    <button class="btn btn-danger">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center">Aucun article trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination responsive #}
    <div class="navigation d-flex justify-content-center mt-3 mt-md-4">
        {{ knp_pagination_render(articles) }}
    </div>
</div>
{% endblock %}