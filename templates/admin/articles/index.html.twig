{# templates/admin/articles/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Administration des articles{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Gestion des articles</h1>

    {# Affichage des messages flash #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Barre de recherche simple #}
    <form method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Rechercher par titre ou résumé..." value="{{ app.request.query.get('search') }}">
            <button class="btn btn-primary" type="submit">Rechercher</button>
            {% if app.request.query.get('search') %}
                <a href="{{ path('app_admin_article_index') }}" class="btn btn-secondary">Réinitialiser</a>
            {% endif %}
        </div>
    </form>

    {# Statistiques rapides #}
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Total articles</h5>
                    <p class="card-text display-4">{{ stats.total|default(0) }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Publiés</h5>
                    <p class="card-text display-4">{{ stats.published|default(0) }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Brouillons</h5>
                    <p class="card-text display-4">{{ stats.drafts|default(0) }}</p>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Titre</th>
                    <th>Auteur</th>
                    <th>Type</th>
                    <th>Images</th>
                    <th>Publié le</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>

                {% for article in articles %}
                    <tr>
                        <td>{{ article.id }}</td>
                        <td>{{ article.title|slice(0, 50) }}{% if article.title|length > 50 %}...{% endif %}</td>
                        <td>{{ article.author.email }}</td>
                        <td>
                            {% set type = article.transactionType|lower %}
                            {% if type == 'acheter' %}
                                <span class="badge rounded-pill px-3 py-2 bg-danger">ACHETER</span>
                            {% elseif type == 'louer' %}
                                <span class="badge rounded-pill px-3 py-2 bg-primary">LOUER</span>
                            {% elseif type == 'brocante' %}
                                <span class="badge rounded-pill px-3 py-2 bg-orange">BROCANTE</span>
                            {% elseif type == 'don' %}
                                <span class="badge rounded-pill px-3 py-2 bg-success">DON</span>
                            {% else %}
                                <span class="badge rounded-pill px-3 py-2 bg-secondary">{{ article.transactionType|upper }}</span>
                            {% endif %}
                        </td>
                        <td>
                        
                            {% if article.images|length > 0 %}
                                <div class="d-flex flex-wrap gap-2">
                                    {% for image in article.images %}
                                        <div class="position-relative">
                                            <img src="{{ asset('uploads/' ~ image.image) }}" alt="miniature" style="width: 50px; height: 50px; object-fit: cover;" class="rounded border">
                                            <form method="post" action="{{ path('app_admin_image_delete', {id: image.id}) }}" style="position: absolute; top: -8px; right: -8px;" onsubmit="return confirm('Supprimer cette image ?')">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_image_' ~ image.id) }}">
<button type="submit" class="btn btn-sm text-muted">✕</button>
                                            </form>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td>{{ article.publishedAt ? article.publishedAt|date('d/m/Y H:i') : '-' }}</td>
                        <td>
                            {% if article.isVerified %}
                                <span class="badge bg-success">Validé</span>
                            {% else %}
                                <span class="badge bg-danger">En attente</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('app_article_show', {slug: article.slug}) }}" class="btn btn-info" target="_blank">Voir</a>
                                <a href="{{ path('app_admin_article_edit', {id: article.id}) }}" class="btn btn-warning">Modifier</a>
                                <form method="post" action="{{ path('app_admin_article_delete', {id: article.id}) }}" style="display:inline-block;" onsubmit="return confirm('Supprimer définitivement cet article ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_delete_article_' ~ article.id) }}">
                                    <button class="btn btn-danger">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center">Aucun article trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination (si KnpPaginator est utilisé) #}
    <div class="navigation d-flex justify-content-center">
        {{ knp_pagination_render(articles) }}
    </div>
</div>
{% endblock %}