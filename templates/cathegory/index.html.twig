{% extends 'base.html.twig' %}

{% block title %}{% trans %}Catégories{% endtrans %}{% endblock %}

{% block body %}

<div class="container my-5">

    <h1 class="mb-4 text-success fw-bold">{% trans %}Catégories{% endtrans %}</h1>
    <h1 class="mb-4 text-success fw-bold">{% trans %}Catégories{% endtrans %}</h1>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle shadow-sm border rounded">
            <thead class="table-success">
                <tr>
                    <th>N°</th>
                    <th>{% trans %}Nom{% endtrans %}</th>
                    <th>{% trans %}actions{% endtrans %}</th>
                </tr>
            </thead>
            <tbody>
            {% for cathegory in cathegories %}
                <tr>
                    <td class="fw-semibold">{{ cathegory.id }}</td>

                    <td class="fw-semibold text-success">
                        {{ cathegory.name }}
                    </td>

                    <td>
                        <a href="{{ path('app_cathegory_show', {'id': cathegory.id}) }}"
                           class="btn btn-sm btn-outline-success me-2">
                            {% trans %}Afficher{% endtrans %}
                        </a>

                        <a href="{{ path('app_cathegory_edit', {'slug': cathegory.slug}) }}"
                           class="btn btn-sm btn-success">
                            {% trans %}Editer{% endtrans %}
                        </a>

                        {{ include('cathegory/_delete_form.html.twig') }}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">
                        {% trans %}Pas d'enregistrements{% endtrans %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <a href="{{ path('app_cathegory_new') }}"
       class="btn btn-success mt-3">
       {% trans %}Créer une nouvelle catégorie{% endtrans %}
    </a>

</div>

{% endblock %}
