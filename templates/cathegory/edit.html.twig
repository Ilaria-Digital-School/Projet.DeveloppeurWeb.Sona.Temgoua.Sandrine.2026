{% extends 'base.html.twig' %}

{% block title %}Edit Category{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-sm">
                <div class="card-body">

                    <h1 class="h3 mb-4 text-success">Edit Category</h1>

                    {{ include('cathegory/_form.html.twig', {'button_label': 'Update'}) }}

                    <div class="d-flex justify-content-between mt-4">
                        <a href="{{ path('app_cathegory_index') }}" class="btn btn-outline-success">
