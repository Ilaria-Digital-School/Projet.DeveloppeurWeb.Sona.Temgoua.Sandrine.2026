{% extends 'base.html.twig' %}

{% block title %}Category{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow-sm">
                <div class="card-body">

                    <h1 class="h3 mb-4 text-success">Category Details</h1>

                    <table class="table table-bordered table-striped align-middle">
                        <tbody>
                            <tr>
                                <th class="w-25">Id</th>
                                <td>{{ cathegory.id }}</td>
                            </tr>
                            <tr>
                                <th>Name</th>
                                <td>{{ cathegory.name }}</td>
                            </tr>
                            <tr>
                                <th>Slug</th>
                                <td>{{ cathegory.slug }}</td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="d-flex justify-content-between mt-4">
                        <a href="{{ path('app_cathegory_index') }}" class="btn btn-outline-success">
                            ← Back to list
                        </a>

                        <div class="d-flex gap-2">
                            <a href="{{ path('app_cathegory_edit', {'id': cathegory.id}) }}" class="btn btn-success">
                                ✏ Edit
                            </a>

                            {{ include('cathegory/_delete_form.html.twig') }}
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}