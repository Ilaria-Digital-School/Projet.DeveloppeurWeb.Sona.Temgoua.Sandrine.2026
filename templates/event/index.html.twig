{% extends 'base.html.twig' %}

{% block title %}Save The Date - Saraka{% endblock %}

{% block body %}

<section class="std-hero position-relative overflow-hidden min-vh-100 d-flex align-items-center">

    <div class="container-xl position-relative">

        <div class="std-overlay"></div>

        <div class="row justify-content-center">

            <div class="col-lg-10 col-xl-9">

                <div class="std-content text-center">

                    <!-- Badge -->

                    <div class="mb-4">

                        <span class="std-badge shadow-sm">

                            <i class="bi bi-clock-history me-2"></i>

                            Bientôt disponible

                        </span>

                    </div>

                    <!-- Titre -->

                    <h1 class="std-title display-2 fw-bold mb-4">

                        Save The <span>Date</span>

                    </h1>

                    <!-- Texte -->

                    <p class="std-intro lead">

                        Parce que <strong>Saraka</strong> n'est pas seulement une plateforme d'annonces.<br>

                        C'est aussi un lieu de rencontre, de partage et de générosité.

                    </p>

                    <p class="std-description fs-5 mx-auto">

                        Imaginez une place de quartier où chacun peut se retrouver autour d'un repas partagé,

                        d'une distribution gratuite ou d'un événement communautaire.

                    </p>

                    <hr class="std-divider my-5">

                    <!-- Fonctionnalités -->

                    <div class="row g-4 std-features justify-content-center">

                        <div class="col-sm-6 col-lg-3">
                            <div class="std-feature h-100">
                                <i class="bi bi-check-circle-fill"></i>
                                <span>Distribution gratuite de vêtements</span>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="std-feature h-100">
                                <i class="bi bi-check-circle-fill"></i>
                                <span>Partage de repas communautaire</span>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="std-feature h-100">
                                <i class="bi bi-check-circle-fill"></i>
                                <span>Veillée de contes, anecdotes et souvenirs</span>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="std-feature h-100">
                                <i class="bi bi-check-circle-fill"></i>
                                <span>Journée d'échange de livres</span>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="std-feature h-100">
                                <i class="bi bi-check-circle-fill"></i>
                                <span>Journée "Ensemble pour un quartier propre"</span>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="std-feature h-100">
                                <i class="bi bi-check-circle-fill"></i>
                                <span>Rencontre interculturelle entre voisins</span>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="std-feature h-100">
                                <i class="bi bi-check-circle-fill"></i>
                                <span>Barbecue ouvert aux voisins</span>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="std-feature h-100">
                                <i class="bi bi-check-circle-fill"></i>
                                <span>Atelier de réparation et de bricolage entre voisins</span>
                            </div>
                        </div>

                    </div>

                    <!-- Carte -->

                    <div class="std-card mt-5 shadow-lg">

                        <div class="row align-items-center g-4">

                            <div class="col-lg-1 text-center">

                                <i class="bi bi-quote std-quote"></i>

                            </div>

                            <div class="col-lg-11 text-start">

                                <h2 class="fw-bold mb-4">

                                    L'esprit Saraka

                                </h2>

                                <p>Un donateur qui souhaite offrir avec joie.</p>

                                <p>Un philanthrope qui veut partager davantage que des biens.</p>

                                <p>Une famille qui organise un repas ouvert au voisinage.</p>

                                <p>Une association qui souhaite rassembler les habitants autour d'une action solidaire.</p>

                                <p class="mt-4 mb-0">

                                    <strong>

                                        Save The Date permettra bientôt à chacun de créer un rendez-vous,

                                        d'inviter sa communauté et de faire naître ces moments simples

                                        qui rapprochent les gens.

                                    </strong>

                                </p>

                            </div>

                        </div>

                    </div>

                    <!-- Boutons -->

                    <div class="std-buttons d-flex flex-column flex-md-row justify-content-center gap-3 mt-5">

                        <a href="{{ path('app_register') }}" class="btn std-btn-primary px-5 py-3" id="notifyBtn">

                            <i class="bi bi-bell-fill me-2"></i>

                            M'avertir au lancement

                        </a>

                        <a href="{{ path('app_home') }}" class="btn std-btn-outline px-5 py-3">

                            <i class="bi bi-arrow-left me-2"></i>

                            Retour à l'accueil

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

{% endblock %}