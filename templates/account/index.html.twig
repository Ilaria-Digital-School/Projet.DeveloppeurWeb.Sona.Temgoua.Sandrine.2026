{% extends 'base.html.twig' %}

{% block title %}Mon compte
{% endblock %}

{% block body %}
	<div class="max-w-4xl mx-auto p-6">

		<h1 class="text-3xl font-bold mb-6">Mon compte</h1>

		<!-- 👤 PROFIL -->
		<div class="bg-white p-4 rounded shadow mb-6">
			<h2 class="text-xl font-semibold mb-2">Profil</h2>
			<p>
				<strong>Nom :</strong>
				{{ app.user.fullName }}</p>
			<p>
				<strong>Bio :</strong>
				{{ app.user.minibio ?? 'Aucune bio' }}</p>
		</div>

				<!-- 📩 CONVERSATIONS -->
<div class="bg-white p-4 rounded shadow mt-4">

    <h2 class="h5 mb-3">Mes conversations</h2>

    <div class="conversation-list">

        {% for conversation in conversations %}

            {% set otherUser = (conversation.buyer == app.user) 
                ? conversation.seller 
                : conversation.buyer %}

            <a href="{{ path('app_conversation_show', {id: conversation.id}) }}"
               class="conversation-item d-flex justify-content-between align-items-center">

                <div>
                    <!-- 👤 NOM -->
                    <div class="fw-semibold">
                        {{ otherUser.fullName }}
                    </div>

                    <!-- 💬 MESSAGE -->
                    <div class="text-muted small">

                        {% if conversation.messages|length > 0 %}
                            {% set lastMessage = conversation.messages|last %}

                            {% if lastMessage.sender == app.user %}
                                <span class="text-success">Vous :</span>
                            {% endif %}

                            {{ lastMessage.content|slice(0, 40) }}

                        {% else %}
                            Aucun message
                        {% endif %}

                    </div>
                </div>

                <!-- ⏰ DATE + BOUTON -->
                <div class="text-end">

                    {% if conversation.updatedAt %}
                        <small class="text-muted d-block">
                            {{ conversation.updatedAt|date('d/m H:i') }}
                        </small>
                    {% endif %}

                    <span class="btn btn-sm btn-outline-primary mt-1">
                        Voir
                    </span>

                </div>

            </a>

        {% else %}
            <p class="text-muted">Aucune conversation</p>
        {% endfor %}

    </div>

</div>
{% endblock %}