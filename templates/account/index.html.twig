{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto p-6">

    <h1 class="text-3xl font-bold mb-6">Mon compte</h1>

    <!-- 👤 PROFIL -->
    <div class="bg-white p-4 rounded shadow mb-6">
        <h2 class="text-xl font-semibold mb-2">Profil</h2>
        <p><strong>Nom :</strong> {{ app.user.fullName }}</p>
        <p><strong>Bio :</strong> {{ app.user.minibio ?? 'Aucune bio' }}</p>
    </div>

    <!-- 📦 MES ANNONCES (pour tout utilisateur) -->
    <div class="bg-white p-4 rounded shadow mb-6">
        <h2 class="text-xl font-semibold mb-3">Mes annonces</h2>
        <div class="d-flex gap-3">
            <a href="{{ path('app_my_articles') }}" class="btn btn-success rounded-pill">Voir mes annonces</a>
            <a href="{{ path('app_article_new') }}" class="btn btn-outline-success rounded-pill">+ Nouvelle annonce</a>
        </div>
    </div>

    <!-- 🔧 ZONE ADMIN (uniquement si l'utilisateur a le rôle ROLE_ADMIN) -->
    {% if is_granted('ROLE_ADMIN') %}
    <div class="bg-white p-4 rounded shadow mb-6">
        <h2 class="text-xl font-semibold mb-3">Administration</h2>
        <div class="d-flex gap-3">
            <a href="{{ path('app_admin_article_index') }}" class="btn btn-danger rounded-pill">⚙️ Gérer tous les articles</a>
            <a href="{{ path('app_admin_conversation_list') }}" class="btn btn-warning rounded-pill">💬 Toutes les conversations</a>
        </div>
    </div>
    {% endif %}

    <!-- 📩 CONVERSATIONS -->
    <div class="bg-white p-4 rounded shadow">
        <h2 class="text-xl font-semibold mb-3">
            {% if is_granted('ROLE_ADMIN') %}
                Toutes les conversations (admin)
            {% else %}
                Mes conversations
            {% endif %}
        </h2>


        <div class="conversation-list">
            {% for conversation in conversations %}

                {% if conversation.messages|length > 0 %}

                    {% set otherUser = (conversation.buyer == app.user) ? conversation.seller : conversation.buyer %}
                    <a href="{{ path('app_conversation_show', {id: conversation.id}) }}" class="conversation-item d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-semibold">{{ otherUser.fullName }}</div>
                            <div class="text-muted small">
                                

                                    {% set lastMessage = conversation.messages|last %}
                                    {% if lastMessage.sender == app.user %}
                                        <span class="text-success">Vous :</span>
                                    {% endif %}
                                    {{ lastMessage.content|slice(0, 40) }}
                                
                                
                            </div>
                        </div>
                        <div class="text-end">
                            {% if conversation.updatedAt %}
                                <small class="text-muted d-block">{{ conversation.updatedAt|date('d/m H:i') }}</small>
                            {% endif %}
                            <span class="btn btn-sm btn-outline-success mt-1">Voir</span>
                        </div>
                    </a>
                    
                {% endif %}
            {% endfor %}
        </div>
    </div>

</div>
{% endblock %}